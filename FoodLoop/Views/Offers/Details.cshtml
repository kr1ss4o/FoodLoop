@model FoodLoop.Models.Entities.Offer

@{
    ViewData["Title"] = Model.Title;
    ViewData["BodyClass"] = "store-body";

    bool isExpired = Model.EndsAt <= DateTime.UtcNow;
    bool isOutOfStock = Model.QuantityAvailable <= 0;
}

<link rel="stylesheet" href="~/css/offer-details.css" />

<div class="details-wrapper">

    <div class="details-grid">

        <!-- IMAGE -->
        <div class="details-image-box">
            <img src="@Model.ImageUrl" class="details-image" />
        </div>

        <!-- INFO -->
        <div class="details-info">

            <div class="details-restaurant">
                by
                <a asp-controller="Restaurant"
                   asp-action="Details"
                   asp-route-id="@Model.Restaurant.Id"
                   class="restaurant-link">
                    @Model.Restaurant.Name
                </a>
            </div>

            <h1 class="details-title">
                @Model.Title
            </h1>

            <!-- TAGS -->
            @if (Model.OfferTags != null && Model.OfferTags.Any())
            {
                <div class="details-tags">
                    @foreach (var tag in Model.OfferTags)
                    {
                        <a asp-controller="Offers"
                           asp-action="Index"
                           asp-route-search="@tag.Tag.Name"
                           class="tag-pill">
                            @tag.Tag.Name
                        </a>
                    }
                </div>
            }

            <!-- PRICE -->
            <div class="details-price-section">

                <span class="details-price">
                    @Model.DiscountedPrice EUR
                </span>

                @if (Model.OriginalPrice > Model.DiscountedPrice)
                {
                    var discount = (int)(100 - (Model.DiscountedPrice / Model.OriginalPrice * 100));

                    <span class="details-original">
                        @Model.OriginalPrice EUR
                    </span>

                    <span class="details-badge">
                        -@discount%
                    </span>
                }

                @if (isExpired)
                {
                    <div class="expired-badge">
                        Expired
                    </div>
                }
                else if (isOutOfStock)
                {
                    <div class="expired-badge out-of-stock">
                        Out of stock
                    </div>
                }

            </div>

            <!-- STOCK -->
            <div class="details-stock">
                @if (!isOutOfStock)
                {
                    if (Model.QuantityAvailable <= 5)
                    {
                        <span class="low-stock">
                            Only @Model.QuantityAvailable left
                        </span>
                    }
                    else
                    {
                        <span>
                            @Model.QuantityAvailable available
                        </span>
                    }
                }
            </div>

            <!-- DESCRIPTION -->
            <p class="details-description">
                @Model.Description
            </p>

            <!-- ADD TO CART -->
            @if (User.Identity.IsAuthenticated)
            {
                if (isExpired || isOutOfStock)
                {
                    <button class="add-btn disabled-btn" disabled>
                        Not available
                    </button>
                }
                else
                {
                    <form id="addToCartForm" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="offerId" value="@Model.Id" />

                        <input type="number"
                               name="quantity"
                               value="1"
                               min="1"
                               max="@Model.QuantityAvailable"
                               class="quantity-input" />

                        <button type="submit" class="add-btn">
                            Add to cart
                        </button>
                    </form>

                }
            }

            <!-- COUNTDOWN -->
            @if (!isExpired)
            {
                <div id="countdown"
                     class="details-countdown"
                     data-end="@Model.EndsAt.ToString("o")">
                </div>
            }

            <div class="details-ends">
                Ends at: @Model.EndsAt.ToString("dd MMM yyyy HH:mm")
            </div>

        </div>

    </div>
</div>

@section Scripts {

    <script>

        // ============================================
        // ADD TO CART (AJAX + LIVE BADGE UPDATE)
        // ============================================

        const form = document.getElementById("addToCartForm");

        if (form) {

            form.addEventListener("submit", async function (e) {

                e.preventDefault();

                const formData = new FormData(form);

                const response = await fetch("/Cart/AddToCart", {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken":
                            form.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                const data = await response.json();

                if (data.success) {

                    showToast("Added to cart!", "success");

                    // 🔥 Trigger global badge update
                    document.dispatchEvent(
                        new CustomEvent("cartUpdated", {
                            detail: { count: data.cartCount }
                        })
                    );

                    // 🔥 Reload mini cart content
                    if (window.loadMiniCart)
                        window.loadMiniCart();
                }
            });
        }

        // ============================================
        // COUNTDOWN TIMER
        // ============================================

        const countdownEl = document.getElementById("countdown");

        if (countdownEl) {

            const endDate = new Date(countdownEl.dataset.end);

            function updateCountdown() {

                const now = new Date();
                const diff = endDate - now;

                if (diff <= 0) {
                    countdownEl.innerText = "Offer expired";
                    return;
                }

                const hours = Math.floor(diff / (1000 * 60 * 60));
                const minutes = Math.floor((diff / (1000 * 60)) % 60);

                countdownEl.innerText = `Ends in ${hours}h ${minutes}m`;
            }

            updateCountdown();
            setInterval(updateCountdown, 60000);
        }

    </script>
}