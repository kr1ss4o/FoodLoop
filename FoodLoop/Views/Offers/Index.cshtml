@model FoodLoop.Models.ViewModels.MarketplaceViewModel
@using FoodLoop.Models.ViewModels

@{
    ViewData["Title"] = "Marketplace";
}

<link rel="stylesheet" href="~/css/store.css" />

<div class="marketplace">

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1>Търсиш нещо за хапване?</h1>

            <form asp-controller="Search" asp-action="Index" method="get" class="hero-search">
                <input type="text"
                       name="query"
                       placeholder="Търси оферти или ресторанти..."
                       class="hero-input" />

                <button type="submit" class="hero-btn">
                    Търси
                </button>
            </form>
        </div>
    </section>

    <!-- CATEGORY BLOCKS -->
    <section class="category-section">
        <div class="category-grid">

            <a asp-controller="Offers" asp-action="Index" asp-route-category="fastfood" class="category-card">
                🍔
                <span>Бърза храна</span>
            </a>

            <a asp-controller="Offers" asp-action="Index" asp-route-category="restaurant" class="category-card">
                🍽
                <span>Ресторанти</span>
            </a>

            <a asp-controller="Offers" asp-action="Index" asp-route-category="supermarket" class="category-card">
                🛒
                <span>Супермаркет</span>
            </a>

            <a asp-controller="Offers" asp-action="Index" asp-route-category="drinks" class="category-card">
                🥤
                <span>Напитки</span>
            </a>

            <a asp-controller="Offers" asp-action="Index" asp-route-category="snacks" class="category-card">
                🍪
                <span>Снакс</span>
            </a>

        </div>
    </section>

    <!-- BREAKFAST -->
    <section class="offer-section">
        <h2>Закуска</h2>

        <div class="store-grid">
            @foreach (var offer in Model.BreakfastOffers)
            {
                @await Html.PartialAsync("_OfferCard", offer)
            }
        </div>

        @await Html.PartialAsync("_SectionPagination",
        new PaginationViewModel { CurrentPage = Model.BreakfastPage, TotalPages = Model.BreakfastTotalPages, Section = "breakfast" })
    </section>

    <!-- LUNCH -->
    <section class="offer-section">
        <h2>Обяд</h2>

        <div class="store-grid">
            @foreach (var offer in Model.LunchOffers)
            {
                @await Html.PartialAsync("_OfferCard", offer)
            }
        </div>

        @await Html.PartialAsync("_SectionPagination",
        new PaginationViewModel { CurrentPage = Model.LunchPage, TotalPages = Model.LunchTotalPages, Section = "lunch" })
    </section>

    <!-- DINNER -->
    <section class="offer-section">
        <h2>Вечеря</h2>

        <div class="store-grid">
            @foreach (var offer in Model.DinnerOffers)
            {
                @await Html.PartialAsync("_OfferCard", offer)
            }
        </div>

        @await Html.PartialAsync("_SectionPagination",
        new PaginationViewModel { CurrentPage = Model.DinnerPage, TotalPages = Model.DinnerTotalPages, Section = "dinner" })
    </section>

</div>