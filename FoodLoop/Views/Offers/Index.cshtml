@model FoodLoop.Models.ViewModels.MarketplaceViewModel
@using FoodLoop.Models.Entities
@using FoodLoop.Models.ViewModels

@{
    ViewData["Title"] = "Маркетплейс";
    ViewData["FullWidth"] = true;

    var trending = ViewBag.TrendingRestaurants as List<Restaurant>;
    var restaurantRatings = ViewBag.RestaurantRatings as Dictionary<Guid, double>;
}

<!-- RANDOM COLOR FOR THE CATEGORIES BACKGROUND -->
@functions {
    string GetCategoryColor(string name)
    {
        var colors = new[]
        {
            "#E8F5E9",
            "#FFF3E0",
            "#E3F2FD",
            "#FCE4EC",
            "#F3E5F5",
            "#E0F7FA"
        };

        int hash = name.GetHashCode();
        int index = Math.Abs(hash) % colors.Length;

        return colors[index];
    }
}

<link rel="stylesheet" href="~/css/store.css" />

<!-- HERO -->
<section class="market-hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6 hero-left">

                <span class="hero-badge">
                    Нови оферти всеки ден
                </span>

                <h1 class="hero-title">
                    Открий <span>вкусна храна</span> близо до теб
                </h1>

                <p class="hero-text">
                    Спаси вкусни ястия от ресторанти и супермаркети на по-ниска цена.
                </p>

                <form asp-controller="Search"
                      asp-action="Index"
                      method="get"
                      class="hero-search">

                    <input type="text"
                           name="query"
                           class="hero-input"
                           placeholder="Търси ресторант или оферта..." />

                    <button class="hero-btn">
                        Търсене
                    </button>

                </form>

            </div>

            <div class="col-lg-6 hero-image-wrap">

                <img src="https://images.unsplash.com/photo-1490645935967-10de6ba17061"
                     class="hero-image" />

            </div>

        </div>

    </div>

</section>

<!-- CATEGORIES -->
<section class="categories-section">

    <div class="categories-wrapper">

        <div class="restaurants-head">

            <div>
                <h2 class="restaurants-title">Разгледай категории</h2>
                <p class="restaurants-subtitle">Популярни категории храна</p>
            </div>

            <div class="restaurants-nav">

                <button type="button" class="restaurants-arrow categories-left">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <button type="button" class="restaurants-arrow categories-right">
                    <i class="bi bi-chevron-right"></i>
                </button>

            </div>

        </div>

        <div class="categories-carousel">

            @foreach (var category in ViewBag.Categories)
            {
                <a asp-controller="Search"
                       asp-action="Index"
                       asp-route-query="@category.Name"
                       class="category-card">

                    <div class="category-icon"
                         style="background:@GetCategoryColor(category.Name)">

                        @category.IconUrl

                    </div>

                    <span class="category-name">@category.Name</span>
                </a>
            }

        </div>

    </div>

</section>

<!-- HIGHEST RATED RESTAURANTS -->
@if (trending != null && trending.Any())
{
    <section class="restaurants-section">

        <div class="restaurants-wrapper">

            <div class="restaurants-container">

                <div class="restaurants-head">

                    <div>
                        <h2 class="restaurants-title">Най-високо оценени ресторанти</h2>
                        <p class="restaurants-subtitle">
                            Водещите ресторанти според потребителите
                        </p>
                    </div>

                </div>

                <div class="restaurants-grid">

                    @foreach (var r in trending)
                    {
                        var rating = restaurantRatings != null && restaurantRatings.ContainsKey(r.Id)
                            ? restaurantRatings[r.Id]
                            : r.Rating;

                        <a asp-controller="Restaurant"
                               asp-action="Details"
                               asp-route-id="@r.Id"
                               class="restaurant-card card-link">

                            <div class="restaurant-image">

                                <img src="@r.BannerImageUrl" class="restaurant-banner" />

                                <div class="restaurant-rating">
                                    <i class="bi bi-star-fill"></i>
                                    @rating.ToString("0.0")
                                </div>

                            </div>

                            <div class="restaurant-body">

                                <img src="@r.ImageUrl" class="restaurant-logo" />

                                <h3 class="restaurant-name">@r.Name</h3>

                                <div class="restaurant-address">
                                    📍 @r.Address
                                </div>

                            </div>

                        </a>
                    }

                </div>

            </div>

        </div>

    </section>
}

<!-- ALL OFFERS -->
@if (Model.Offers != null && Model.Offers.Any())
{
    <section class="offers-section">

        <div class="offers-wrapper">

            <form method="get" asp-controller="Offers" asp-action="Index" id="offersForm">

                <div class="offers-header">

                    <div class="offers-header-left">
                        <h2>Нашите предложения</h2>
                        <p>Разгледайте наличните оферти</p>
                    </div>

                    <div class="offers-sort">

                        <label for="sortSelect" class="sort-label">
                            <i class="bi bi-sort-down"></i>
                            Сортиране
                        </label>

                        <select id="sortSelect" name="sort" class="sort-select">
                            <option value="" selected="@(string.IsNullOrEmpty(Model.Sort))">Най-нови</option>
                            <option value="oldest" selected="@(Model.Sort == "oldest")">Най-стари</option>
                            <option value="rating_desc" selected="@(Model.Sort == "rating_desc")">Рейтинг</option>
                            <option value="price_asc" selected="@(Model.Sort == "price_asc")">Цена ↑</option>
                            <option value="price_desc" selected="@(Model.Sort == "price_desc")">Цена ↓</option>
                        </select>

                    </div>

                </div>

            </form>

            <div class="offers-grid" id="offersGrid">

                @foreach (var offer in Model.Offers)
                {
                    var rating = restaurantRatings != null && restaurantRatings.ContainsKey(offer.RestaurantId)
                        ? restaurantRatings[offer.RestaurantId]
                        : offer.Restaurant?.Rating ?? 4.5;

                    <a asp-controller="Offers"
                           asp-action="Details"
                           asp-route-id="@offer.Id"
                           class="offer-card card-link">

                        <div class="offer-image">
                            <img src="@offer.ImageUrl">

                            <div class="offer-rating">
                                <i class="bi bi-star-fill"></i>
                                @rating.ToString("0.0")
                            </div>
                        </div>

                        <div class="offer-body">

                            <h3 class="offer-title">
                                @offer.Title
                            </h3>

                            <div class="offer-restaurant">
                                @offer.Restaurant?.Name
                            </div>

                            <div class="offer-price-row">

                                <div class="offer-price">
                                    @offer.DiscountedPrice EUR
                                </div>

                                <div class="offer-stock">
                                    @offer.QuantityAvailable налични
                                </div>

                            </div>

                            <div class="offer-timer">
                                <i class="bi bi-hourglass-split"></i>
                                @(offer.EndsAt.Subtract(DateTime.UtcNow).TotalHours.ToString("0"))ч
                            </div>

                        </div>

                    </a>
                }

            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center" id="offersPagination">

                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link" onclick="loadPage(@(Model.CurrentPage - 1))">«</button>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <button class="page-link" onclick="loadPage(@i)">@i</button>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <button class="page-link" onclick="loadPage(@(Model.CurrentPage + 1))">»</button>
                        </li>

                    </ul>
                </nav>
            }

            </div>

    </section>
}

<script>
    if (!window.carouselInitialized) {

        window.carouselInitialized = true;

        const carousel = document.querySelector(".categories-carousel");
        const btnLeft = document.querySelector(".categories-left");
        const btnRight = document.querySelector(".categories-right");

        function getScrollAmount() {
            const card = carousel.querySelector(".category-card");
            const gap = parseInt(getComputedStyle(carousel).gap) || 0;
            return card.offsetWidth + gap;
        }

        btnRight.addEventListener("click", (e) => {
            e.preventDefault();
            carousel.scrollLeft += getScrollAmount();
        });

        btnLeft.addEventListener("click", (e) => {
            e.preventDefault();
            carousel.scrollLeft -= getScrollAmount();
        });
    }

    const sortSelect = document.getElementById("sortSelect");
    if (sortSelect) {
        sortSelect.addEventListener("change", function () {
            document.getElementById("offersForm").submit();
        });
    }

        async function loadPage(page) {
        const sort = document.getElementById("sortSelect")?.value ?? "";

        const response = await fetch(`/Offers/PagedOffers?page=${page}&sort=${sort}`);
        if (!response.ok) return;

        const html = await response.text();

        document.getElementById("offersGrid").innerHTML = html;
        updatePagination(page);
    }

        function updatePagination(activePage) {
        const items = document.querySelectorAll("#offersPagination .page-item");
        const totalPages = items.length - 2;

        items.forEach((item, index) => {
            const btn = item.querySelector(".page-link");
            if (!btn) return;

            if (index === 0) {
                item.classList.toggle("disabled", activePage === 1);
                btn.onclick = activePage === 1 ? null : () => loadPage(activePage - 1);
                return;
            }

            if (index === items.length - 1) {
                item.classList.toggle("disabled", activePage === totalPages);
                btn.onclick = activePage === totalPages ? null : () => loadPage(activePage + 1);
                return;
            }

            const pageNum = parseInt(btn.textContent.trim());
            item.classList.toggle("active", pageNum === activePage);
        });
    }

</script>
