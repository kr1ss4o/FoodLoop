@model FoodLoop.Models.ViewModels.MarketplaceViewModel
@using FoodLoop.Models.Entities
@using FoodLoop.Models.ViewModels

@{
    ViewData["Title"] = "Маркетплейс";
    ViewData["FullWidth"] = true;

    var trending = ViewBag.TrendingRestaurants as List<Restaurant>;
    var trendingOffers = ViewBag.TrendingOffers as List<Offer>;

    var restaurantRatings = ViewBag.RestaurantRatings as Dictionary<Guid, double>;
}

<link rel="stylesheet" href="~/css/store.css" />

<!-- HERO -->
<section class="market-hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6 hero-left">

                <span class="hero-badge">
                    Нови оферти всеки ден
                </span>

                <h1 class="hero-title">
                    Открий <span>вкусна храна</span> близо до теб
                </h1>

                <p class="hero-text">
                    Спаси вкусни ястия от ресторанти и супермаркети на по-ниска цена.
                </p>

                <form asp-controller="Search"
                      asp-action="Index"
                      method="get"
                      class="hero-search">

                    <input type="text"
                           name="query"
                           class="hero-input"
                           placeholder="Търси ресторант или оферта..." />

                    <button class="hero-btn">
                        Търсене
                    </button>

                </form>

            </div>

            <div class="col-lg-6 hero-image-wrap">

                <img src="https://images.unsplash.com/photo-1490645935967-10de6ba17061"
                     class="hero-image" />

            </div>

        </div>

    </div>

</section>

<!-- CATEGORIES -->
<section class="categories-section">

    <div class="categories-wrapper">

        <div class="restaurants-head">

            <div>
                <h2 class="restaurants-title">Разгледай категории</h2>
                <p class="restaurants-subtitle">Популярни категории храна</p>
            </div>

            <div class="restaurants-nav">

                <button class="restaurants-arrow categories-left">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <button class="restaurants-arrow categories-right">
                    <i class="bi bi-chevron-right"></i>
                </button>

            </div>

        </div>

        <div class="categories-carousel">

            <a asp-controller="Search" asp-action="Index" asp-route-query="Азиатска храна" class="category-card">
                <div class="category-icon asian">🍜</div>
                <span>Азиатска храна</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Бургери" class="category-card">
                <div class="category-icon burger">🍔</div>
                <span>Бургери</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Бърза храна" class="category-card">
                <div class="category-icon fastfood">🍟</div>
                <span>Бърза храна</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Вечеря" class="category-card">
                <div class="category-icon dinner">🍽️</div>
                <span>Вечеря</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Грил" class="category-card">
                <div class="category-icon grill">🍖</div>
                <span>Грил</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Десерт" class="category-card">
                <div class="category-icon dessert">🍰</div>
                <span>Десерт</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Закуска" class="category-card">
                <div class="category-icon breakfast">🥐</div>
                <span>Закуска</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Здравословно" class="category-card">
                <div class="category-icon healthy">🥗</div>
                <span>Здравословно</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Морски дарове" class="category-card">
                <div class="category-icon seafood">🦐</div>
                <span>Морски дарове</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Обяд" class="category-card">
                <div class="category-icon lunch">🍛</div>
                <span>Обяд</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Паста" class="category-card">
                <div class="category-icon pasta">🍝</div>
                <span>Паста</span>
            </a>

            <a asp-controller="Search" asp-action="Index" asp-route-query="Пица" class="category-card">
                <div class="category-icon pizza">🍕</div>
                <span>Пица</span>
            </a>

        </div>

    </div>

</section>

<!-- TRENDING RESTAURANTS -->
@if (trending != null && trending.Any())
{
    <section class="restaurants-section">

        <div class="restaurants-wrapper">

            <div class="restaurants-container">

                <div class="restaurants-head">

                    <div>
                        <h2 class="restaurants-title">Популярни ресторанти</h2>
                        <p class="restaurants-subtitle">Най-предпочитаните места във вашия район</p>
                    </div>

                    <div class="restaurants-nav">

                        <button class="restaurants-arrow left">
                            <i class="bi bi-chevron-left"></i>
                        </button>

                        <button class="restaurants-arrow right">
                            <i class="bi bi-chevron-right"></i>
                        </button>

                    </div>

                </div>

                <div class="restaurants-carousel">

                    @foreach (var r in trending)
                    {
                        var rating = restaurantRatings != null && restaurantRatings.ContainsKey(r.Id)
                            ? restaurantRatings[r.Id]
                            : r.Rating;

                        <a asp-controller="Restaurant"
                               asp-action="Details"
                               asp-route-id="@r.Id"
                               class="restaurant-card card-link">

                            <div class="restaurant-image">

                                <img src="@r.BannerImageUrl" class="restaurant-banner" />

                                <div class="restaurant-rating">
                                    <i class="bi bi-star-fill"></i>
                                    @rating.ToString("0.0")
                                </div>

                            </div>

                            <div class="restaurant-body">

                                <img src="@r.ImageUrl" class="restaurant-logo" />

                                <h3 class="restaurant-name">@r.Name</h3>

                                <div class="restaurant-tags">
                                    Италианска • Пица • Паста
                                </div>

                                <div class="restaurant-meta">

                                    <span>
                                        <i class="bi bi-clock"></i>
                                        25-35 мин
                                    </span>

                                    <span>
                                        <i class="bi bi-bicycle"></i>
                                        2€ доставка
                                    </span>

                                </div>

                            </div>

                        </a>
                    }

                </div>

            </div>

        </div>

    </section>
}


<!-- TRENDING OFFERS -->
@if (trendingOffers != null && trendingOffers.Any())
{
    <section class="offers-section">

        <div class="offers-wrapper">

            <div class="offers-header">
                <h2>Най-популярни оферти</h2>
                <p>Най-търсените предложения в момента</p>
            </div>

            <div class="offers-grid">

                @foreach (var offer in trendingOffers)
                {
                    var rating = restaurantRatings != null && restaurantRatings.ContainsKey(offer.RestaurantId)
                        ? restaurantRatings[offer.RestaurantId]
                        : offer.Restaurant?.Rating ?? 4.5;

                    <a asp-controller="Offers"
                           asp-action="Details"
                           asp-route-id="@offer.Id"
                           class="offer-card card-link">

                        <div class="offer-image">
                            <img src="@offer.ImageUrl">

                            <div class="offer-rating">
                                <i class="bi bi-star-fill"></i>
                                @rating.ToString("0.0")
                            </div>
                        </div>

                        <div class="offer-body">

                            <h3 class="offer-title">
                                @offer.Title
                            </h3>

                            <div class="offer-restaurant">
                                @offer.Restaurant?.Name
                            </div>

                            <div class="offer-price-row">

                                <div class="offer-price">
                                    @offer.DiscountedPrice EUR
                                </div>

                                <div class="offer-stock">
                                    @offer.QuantityAvailable налични
                                </div>

                            </div>

                            <div class="offer-timer">
                                <i class="bi bi-hourglass-split"></i>
                                @(offer.EndsAt.Subtract(DateTime.UtcNow).TotalHours.ToString("0"))ч
                            </div>

                        </div>

                    </a>
                }

            </div>

        </div>

    </section>
}


<!-- BENEFITS -->
<section class="benefits-section">

    <div class="benefits-wrapper">

        <div class="benefit-item">

            <div class="benefit-icon">
                <i class="bi bi-clock"></i>
            </div>

            <h3>Бърза доставка</h3>

            <p>
                Получи храната си до 30 минути.
                Следи поръчката си в реално време.
            </p>

        </div>

        <div class="benefit-item">

            <div class="benefit-icon">
                <i class="bi bi-shield-check"></i>
            </div>

            <h3>Свежо и безопасно</h3>

            <p>
                Всички наши партньори спазват
                строги хигиенни стандарти.
                Гарантирана свежест.
            </p>

        </div>

        <div class="benefit-item">

            <div class="benefit-icon">
                <i class="bi bi-percent"></i>
            </div>

            <h3>Най-добрите оферти</h3>

            <p>
                Ексклузивни намаления и предложения
                от любимите ти ресторанти.
            </p>

        </div>

    </div>

</section>

<script>

    document.addEventListener("DOMContentLoaded", function(){

    const carousel = document.querySelector(".categories-carousel")

    const left = document.querySelector(".categories-left")

    const right = document.querySelector(".categories-right")

    if(!carousel) return

    const scrollAmount = carousel.clientWidth

    right.addEventListener("click", () => {

    carousel.scrollBy({
    left:scrollAmount,
    behavior:"smooth"
    })

    })

    left.addEventListener("click", () => {

    carousel.scrollBy({
    left:-scrollAmount,
    behavior:"smooth"
    })

    })

    })

</script>