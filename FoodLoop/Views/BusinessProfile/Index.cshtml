@model FoodLoop.Models.ViewModels.BusinessProfileViewModel
@{
    ViewData["Title"] = "Business Dashboard";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/business-profile.css" asp-append-version="true" />

<div class="bp-wrapper">

    <!-- ============ WELCOME BAR ============ -->
    <div class="bp-topbar">
        <div>
            <div class="bp-welcome-text">Добре дошъл,</div>
            <div class="bp-welcome-name">@Model.OwnerName</div>
        </div>

        <div class="bp-top-actions">
            <button id="epm-open" class="bp-btn-edit">
                <svg class="bp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 20h9" />
                    <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                </svg>
                Редактирай
            </button>
        </div>
    </div>

    <!-- ============ HERO ============ -->
    <section class="bp-hero"
             style="background-image: url('@(string.IsNullOrEmpty(Model.BannerImageUrl)
                                            ? "/images/placeholders/banner-default.jpg"
                                            : Model.BannerImageUrl)')">

        <div class="bp-hero-overlay">

            <div class="bp-hero-content">

                <div class="bp-hero-left">
                    <h1 class="bp-hero-title">@Model.RestaurantName</h1>

                    <div class="bp-hero-rating">
                        <a href="/RestaurantReviews/Index">
                            ★ @Model.AverageRating.ToString("0.0")
                            <span class="bp-muted">
                                (@Model.ReviewCount reviews)
                            </span>
                        </a>
                    </div>

                    <div class="bp-hero-meta">
                        <span>@Model.BusinessEmail</span>
                        <span>@Model.Phone</span>
                        <span>@Model.Address</span>
                    </div>
                </div>

                <div class="bp-hero-right">
                    <img class="bp-hero-logo"
                         src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                                       ? "/images/default-restaurant.jpg"
                                                       : Model.ImageUrl)" />
                </div>

            </div>

        </div>
    </section>

    <!-- ============ STATS SECTION ============ -->
    <section class="bp-stats">
        <div class="bp-stat-card">
            <div class="bp-stat-value">@Model.ReviewCount</div>
            <div class="bp-stat-label">Всички ревюта:</div>
        </div>

        <div class="bp-stat-card">
            <div class="bp-stat-value">@Model.AverageRating.ToString("0.0")</div>
            <div class="bp-stat-label">Рейтинг:</div>
        </div>

        <div class="bp-stat-card">
            <div class="bp-stat-value">@Model.ActiveOffers</div>
            <div class="bp-stat-label">Активни оферти:</div>
        </div>

        <div class="bp-stat-card">
            <div class="bp-stat-value">@Model.TotalReservations</div>
            <div class="bp-stat-label">Завършени оферти:</div>
        </div>
    </section>

    <!-- ============ OWNER SECTION ============ -->
    <section class="bp-section">
        <div class="bp-section-head">
            <h2>Детайли на собственик:</h2>
        </div>

        <div class="bp-owner-grid">
            <div class="bp-owner-card">
                <span class="bp-label">Пълно име:</span>
                <span class="bp-value">@Model.OwnerName</span>
            </div>

            <div class="bp-owner-card">
                <span class="bp-label">Имейл:</span>
                <span class="bp-value">@Model.OwnerEmail</span>
            </div>

            <div class="bp-owner-card">
                <span class="bp-label">Телефон:</span>
                <span class="bp-value">@Model.OwnerPhone</span>
            </div>

            <div class="bp-owner-card">
                <span class="bp-label">Дата на създаване на профил:</span>
                <span class="bp-value">@Model.AccountCreated.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    </section>

</div>

@await Html.PartialAsync("_EditProfileModal", Model.EditProfileModal)

@section Scripts {
    <script src="~/js/profile-edit-modal.js" asp-append-version="true"></script>
}