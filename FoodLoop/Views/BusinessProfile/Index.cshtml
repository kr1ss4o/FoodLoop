@model FoodLoop.Models.ViewModels.BusinessProfileViewModel
@{
    ViewData["Title"] = "Business Dashboard";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/business-profile.css" asp-append-version="true" />

<div class="bp-wrapper">

    <h1 class="bp-title">Hello, @Model.OwnerName</h1>

    <!-- MAIN PANEL -->
    <div class="bp-main-card">

        <!-- LEFT COLUMN (text info) -->
        <div class="bp-info">

            <h2 class="bp-section-head">Business details</h2>

            <div class="bp-row">
                <span class="bp-label">Restaurant name</span>
                <span id="rest-name" class="bp-value">@Model.RestaurantName</span>
            </div>

            <div class="bp-row">
                <span class="bp-label">Business email</span>
                <span id="rest-email" class="bp-value">@Model.BusinessEmail</span>
            </div>

            <div class="bp-row">
                <span class="bp-label">Phone</span>
                <span id="rest-phone" class="bp-value">@Model.Phone</span>
            </div>

            <div class="bp-row">
                <span class="bp-label">Address</span>
                <span id="rest-address" class="bp-value">@Model.Address</span>
            </div>

            <button id="epm-open" class="bp-edit-btn">Edit profile</button>
        </div>

        <!-- RIGHT COLUMN (image) -->
        <div class="bp-photo">
            <img id="rest-photo" src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                     ? "/images/default-restaurant.jpg"
                                     : Model.ImageUrl)"
                 alt="Restaurant photo" />
        </div>

    </div>


    <!-- OWNER SECTION -->
    <h2 class="bp-section-title">Owner details</h2>

    <div class="bp-owner-grid">

        <div class="bp-owner-card">
            <span class="bp-owner-label">Full name</span>
            <span id="owner-name" class="bp-owner-value">@Model.OwnerName</span>
        </div>

        <div class="bp-owner-card">
            <span class="bp-owner-label">Email</span>
            <span id="owner-email" class="bp-owner-value">@Model.OwnerEmail</span>
        </div>

        <div class="bp-owner-card">
            <span class="bp-owner-label">Phone</span>
            <span id="owner-phone" class="bp-owner-value">@Model.OwnerPhone</span>
        </div>

        <div class="bp-owner-card">
            <span class="bp-owner-label">Account created</span>
            <span class="bp-owner-value">@Model.AccountCreated.ToShortDateString()</span>
        </div>

    </div>

    <!-- BUTTONS -->
    <form method="post" action="/Account/Logout">
        <button class="bp-logout-btn">Log out</button>
    </form>

    <form method="post" action="/Profile/Delete" onsubmit="return confirm('Delete this account permanently?');">
        <button class="bp-delete-btn">Delete account</button>
    </form>

</div>

@await Html.PartialAsync("_EditProfileModal", Model.EditProfileModal)

@section Scripts {
    <script src="~/js/profile-edit-modal.js" asp-append-version="true"></script>
}