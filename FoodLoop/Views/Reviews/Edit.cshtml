@{
    var reservationId = (Guid)ViewBag.ReservationId;
    var rating = (int)ViewBag.Rating;
    var comment = ViewBag.Comment as string;
}

<h2>Edit Review</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" name="reservationId" value="@reservationId" />

    <select name="rating">
        @for (int i = 1; i <= 5; i++)
        {
            <option value="@i" selected="@(i == rating)">
                @i ⭐
            </option>
        }
    </select>

    <textarea name="comment">@comment</textarea>

    <button class="btn btn-primary mt-2">
        Save
    </button>
</form>