@model FoodLoop.Models.ViewModels.SearchViewModel
@using FoodLoop.Models.ViewModels

<link rel="stylesheet" href="~/css/search.css" />

@{
    ViewData["Title"] = "FoodLoop - Търсачка";
    ViewData["FullWidth"] = true;
    var restaurantRatings = ViewBag.RestaurantRatings as Dictionary<Guid, double>;
}

<div class="search-page">

    <div class="search-container">

        <!-- ===================== -->
        <!-- SEARCH HEADER -->
        <!-- ===================== -->

        <div class="search-header">

            <form asp-action="Index" method="get" class="search-form">

                <div class="search-input-wrap">

                    <i class="bi bi-search search-icon"></i>

                    <input type="text"
                           name="query"
                           value="@Model.Query"
                           class="search-input"
                           placeholder="Търси оферти или ресторанти..." />

                </div>

                <button class="search-btn">
                    Търси
                </button>

                <div class="search-sort-wrap">

                    <i class="bi bi-sliders search-sort-icon"></i>

                    <select name="sort" class="search-sort" id="sortSelect">

                        <option value="" selected="@(string.IsNullOrEmpty(Model.Sort))">
                            Сортирай
                        </option>

                        <option value="expiring_soon" selected="@(Model.Sort == "expiring_soon")">
                            Изтичат скоро
                        </option>

                        <option value="rating_desc" selected="@(Model.Sort == "rating_desc")">
                            Най-висок рейтинг
                        </option>

                        <option value="price_asc" selected="@(Model.Sort == "price_asc")">
                            Цена ↑
                        </option>

                        <option value="price_desc" selected="@(Model.Sort == "price_desc")">
                            Цена ↓
                        </option>

                        <option value="newest" selected="@(Model.Sort == "newest")">
                            Най-нови
                        </option>

                    </select>

                </div>

            </form>

            <!-- RESULTS COUNT -->

            @if (Model.OffersCount == 0 && Model.RestaurantsCount == 0)
            {
                <div class="search-results-count">
                    Няма намерени резултати
                </div>
            }
            else
            {
                <div class="search-results-count">
                    Намерени @Model.OffersCount оферти и @Model.RestaurantsCount ресторанта
                </div>
            }

        </div>

        <!-- ===================== -->
        <!-- OFFERS -->
        <!-- ===================== -->

        @if (Model.Offers.Any())
        {
            <div class="search-section">

                <div class="search-section-header">

                    <h2 class="section-title">
                        Оферти
                    </h2>

                    <p class="section-subtitle">
                        Намери намалени предложения от ресторанти близо до теб.
                    </p>

                </div>

                <div class="search-grid offers-grid">

                    @foreach (var offer in Model.Offers)
                    {
                        var rating = restaurantRatings != null && restaurantRatings.ContainsKey(offer.RestaurantId)
                            ? restaurantRatings[offer.RestaurantId]
                            : offer.Restaurant?.Rating ?? 4.5;

                        <a asp-controller="Offers"
                               asp-action="Details"
                               asp-route-id="@offer.Id"
                               class="offer-card card-link">

                            <div class="offer-image">

                                <img src="@offer.ImageUrl">

                                <div class="offer-rating">
                                    <i class="bi bi-star-fill"></i>
                                    @rating.ToString("0.0")
                                </div>

                            </div>

                            <div class="offer-body">

                                <h3 class="offer-title">
                                    @offer.Title
                                </h3>

                                <div class="offer-restaurant">
                                    @offer.Restaurant?.Name
                                </div>

                                <div class="offer-price-row">

                                    <div class="offer-price">
                                        @offer.DiscountedPrice EUR
                                    </div>

                                    <div class="offer-stock">
                                        @offer.QuantityAvailable налични
                                    </div>

                                </div>

                                <div class="offer-timer">
                                    <i class="bi bi-hourglass-split"></i>
                                    @(offer.EndsAt.Subtract(DateTime.UtcNow).TotalHours.ToString("0"))ч
                                </div>

                            </div>

                        </a>
                    }

                </div>

                <partial name="_SearchPagination" model='new PaginationViewModel
                    {
                    CurrentPage = Model.CurrentPage,
                    TotalPages = Model.TotalPages,
                    Controller = "Search",
                    Action = "Index",
                    Query = Model.Query,
                        Sort = Model.Sort,
                    CategoryId = Model.CategoryId,
                    Section = "offers"
                    }'
                />
            </div>
        }


        <!-- ===================== -->
        <!-- RESTAURANTS -->
        <!-- ===================== -->

        @if (Model.Restaurants.Any())
        {
            <div class="search-section">

                <div class="search-section-header">

                    <h2 class="section-title">
                        Ресторанти
                    </h2>

                    <p class="section-subtitle">
                        Открий ресторанти, които предлагат оферти в FoodLoop.
                    </p>

                </div>

                <div class="search-grid restaurants-grid">

                    @foreach (var r in Model.Restaurants)
                    {
                        var rating = restaurantRatings != null && restaurantRatings.ContainsKey(r.Id)
                            ? restaurantRatings[r.Id]
                            : r.Rating;

                        <a asp-controller="Restaurant"
                               asp-action="Details"
                               asp-route-id="@r.Id"
                               class="restaurant-card card-link">

                            <div class="restaurant-image">

                                <img src="@r.BannerImageUrl" class="restaurant-banner" />

                                <div class="restaurant-rating">
                                    <i class="bi bi-star-fill"></i>
                                    @rating.ToString("0.0")
                                </div>

                            </div>

                            <div class="restaurant-body">

                                <img src="@r.ImageUrl" class="restaurant-logo" />

                                <h3 class="restaurant-name">@r.Name</h3>

                                <div class="restaurant-tags">
                                    Италианска • Пица • Паста
                                </div>

                                <div class="restaurant-meta">

                                    <span>
                                        <i class="bi bi-clock"></i>
                                        25-35 мин
                                    </span>

                                    <span>
                                        <i class="bi bi-bicycle"></i>
                                        2€ доставка
                                    </span>

                                </div>

                            </div>

                        </a>
                    }

                </div>

                <partial name="_SearchPagination" model='new PaginationViewModel
                    {
                        CurrentPage = Model.RestaurantsCurrentPage,
                        TotalPages = Model.RestaurantPages,
                        Controller = "Search",
                        Action = "Index",
                        Query = Model.Query,
                        Sort = Model.Sort,
                        CategoryId = Model.CategoryId,
                        Section = "restaurants"
                    }'
                />
            </div>
        }

    </div>

</div>

@section Scripts {

    <script>

        // Apply filter wihtout reloading the page

        const sortSelect = document.getElementById("sortSelect");

        if (sortSelect) {
            sortSelect.addEventListener("change", function () {
                this.closest("form").submit();
            });
        }

        // Offer countdown timer

        document.querySelectorAll(".countdown").forEach(el => {

            const end = new Date(el.dataset.end);

            function update() {

                const now = new Date();
                const diff = end - now;

                if (diff <= 0) {
                    el.innerText = "Изтекла";
                    return;
                }

                const hours = Math.floor(diff / (1000 * 60 * 60));
                const minutes = Math.floor((diff / (1000 * 60)) % 60);

                el.innerText = `⏳ ${hours}ч ${minutes}м`;
            }

            update();
            setInterval(update, 60000);

        });

    </script>

}
