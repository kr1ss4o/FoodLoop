@using FoodLoop.Models.Enums
@model FoodLoop.Models.ViewModels.CartPageViewModel


@{
    ViewData["Title"] = "My Orders";
    ViewData["BodyClass"] = "profile-body";

    var cart = Model.CartItems;
    var reservations = Model.Reservations;

    var ongoing = reservations
        .Where(r => r.Status == ReservationStatus.Pending || r.Status == ReservationStatus.Confirmed)
        .ToList();

    var history = reservations
        .Where(r => r.Status == ReservationStatus.Finished || r.Status == ReservationStatus.Canceled)
        .ToList();

    decimal total = cart.Sum(c => c.Offer.DiscountedPrice * c.Quantity);
}

<link rel="stylesheet" href="~/css/cart.css" />


<!-- ========================================================= -->
<!-- ORDER CHECKOUT SECTION -->
<!-- ========================================================= -->
<h2 class="section-title">Order checkout</h2>

@if (!cart.Any())
{
    <p class="empty-text">Your cart is empty.</p>
}
else
{
    foreach (var item in cart)
    {
        <div class="cart-item-card">

            <div class="left-part">
                <p class="item-title">@item.Offer.Title</p>
                <p class="item-restaurant">by @item.Offer.Restaurant.Name</p>

                <div class="quantity-controls">
                    <form asp-action="DecreaseQuantity" method="post">
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <button class="qty-btn">-</button>
                    </form>

                    <span class="qty-number">@item.Quantity</span>

                    <form asp-action="IncreaseQuantity" method="post">
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <button class="qty-btn">+</button>
                    </form>
                </div>

                <form asp-action="RemoveFromCart" method="post">
                    <input type="hidden" name="id" value="@item.Id" />
                    <button class="remove-btn">Remove</button>
                </form>
            </div>

            <img src="@item.Offer.ImageUrl" class="cart-item-image" />
        </div>
    }

    <div class="checkout-total">
        <strong>Order total:</strong> @total EUR
    </div>

    <form asp-action="Checkout" method="post" class="checkout-actions">
        <button class="order-now-btn">Order now</button>
        <a href="/Home/Index" class="cancel-order-btn">Cancel</a>
    </form>
}



<!-- ========================================================= -->
<!-- ONGOING ORDERS -->
<!-- ========================================================= -->
@if (ongoing.Any())
{
    <h2 class="section-title" style="margin-top: 40px;">Ongoing orders:</h2>

    foreach (var o in ongoing)
    {
        <div class="order-card">

            <div class="order-info">
                <p class="title">@o.Offer.Title</p>

                <p><strong>Restaurant:</strong> @o.Offer.Restaurant.Name</p>
                <p><strong>Client:</strong> @o.User.FullName</p>
                <p><strong>Phone:</strong> @o.User.PhoneNumber</p>
            </div>

            <div class="status-box">
                @if (o.Status == ReservationStatus.Pending)
                {
                    <span class="status pending">Pending</span>
                }
                else if (o.Status == ReservationStatus.Confirmed)
                {
                    <span class="status confirmed">Confirmed</span>
                }

                <form method="post" action="/Reservation/Cancel">
                    <input type="hidden" name="id" value="@o.Id" />
                    <button class="cancel-btn">Cancel</button>
                </form>
            </div>

            <img src="@o.Offer.ImageUrl" class="order-image" />
        </div>
    }
}



<!-- ========================================================= -->
<!-- ORDER HISTORY -->
<!-- ========================================================= -->
<h2 class="section-title" style="margin-top: 40px;">Order history:</h2>

@if (!history.Any())
{
    <p class="empty-text">You have no past orders.</p>
}
else
{
    int shown = 3;
    var firstThree = history.Take(shown).ToList();
    var remaining = history.Skip(shown).ToList();

    foreach (var h in firstThree)
    {
        <div class="order-card history">
            <div class="order-info">
                <p class="title">@h.Offer.Title</p>
                <p><strong>Client:</strong> @h.User.FullName</p>
                <p><strong>Phone:</strong> @h.User.PhoneNumber</p>

                <p>
                    <strong>Status:</strong>
                    <span class="history-status @(h.Status == ReservationStatus.Finished ? "finished" : "canceled")">
                        @h.Status
                    </span>
                </p>
            </div>
            <img src="@h.Offer.ImageUrl" class="order-image" />
        </div>
    }

    if (remaining.Any())
    {
        <button id="showMoreBtn" class="show-more-btn">Show more</button>

        <div id="moreHistory" style="display:none;">
            @foreach (var h in remaining)
            {
                <div class="order-card history">
                    <div class="order-info">
                        <p class="title">@h.Offer.Title</p>
                        <p><strong>Client:</strong> @h.User.FullName</p>
                        <p><strong>Phone:</strong> @h.User.PhoneNumber</p>

                        <p>
                            <strong>Status:</strong>
                            <span class="history-status @(h.Status == ReservationStatus.Finished ? "finished" : "canceled")">
                                @h.Status
                            </span>
                        </p>
                    </div>
                    <img src="@h.Offer.ImageUrl" class="order-image" />
                </div>
            }
        </div>
    }
}

@section Scripts {
    <script src="~/js/cart.js"></script>

    <script>
        @if (TempData["Success"] != null)
        {
            <text> showToast("@TempData["Success"]", "success"); </text>
        }
        @if (TempData["Error"] != null)
        {
            <text> showToast("@TempData["Error"]", "error"); </text>
        }
    </script>
}