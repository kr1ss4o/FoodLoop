@using FoodLoop.Models.Enums
@using FoodLoop.Models.Entities
@model FoodLoop.Models.ViewModels.CartPageViewModel
@using FoodLoop.Helpers

@{
    ViewData["Title"] = "Моите поръчки";

    var cart = Model.CartItems ?? new List<CartItem>();
    var reservations = Model.Reservations ?? new List<Reservation>();

    var ongoing = reservations
        .Where(r => r.Status == ReservationStatus.Pending ||
                    r.Status == ReservationStatus.Confirmed ||
                    r.Status == ReservationStatus.OutForDelivery)
        .ToList();

    var history = reservations
        .Where(r => r.Status == ReservationStatus.Finished ||
                    r.Status == ReservationStatus.Canceled)
        .ToList();

    decimal total = cart.Sum(c => (decimal)c.Offer.DiscountedPrice * c.Quantity);
}

@functions {
    private bool HasReachedStatus(Reservation order, ReservationStatus status)
    {
        if (status == ReservationStatus.Pending)
            return true;

        return order.StatusLogs.Any(l => l.NewStatus == status)
               || order.Status == status;
    }

    private DateTime? GetStatusTime(Reservation order, ReservationStatus status)
    {
        if (status == ReservationStatus.Pending)
            return order.CreatedAt;

        return order.StatusLogs
            .Where(l => l.NewStatus == status)
            .OrderBy(l => l.ChangedAt)
            .Select(l => (DateTime?)l.ChangedAt)
            .FirstOrDefault();
    }

    private ReservationStatus GetCurrentStep(Reservation order)
    {
        return order.Status;
    }
}

<link rel="stylesheet" href="~/css/cart.css" />
<link rel="stylesheet" href="~/css/timeline.css" />

<div class="orders-wrapper">

    <div class="mb-4">
        <h2 class="fw-bold">Моите поръчки</h2>
        <p class="text-muted">Проследявайте и управлявайте вашите поръчки</p>
    </div>

    <ul class="nav nav-pills mb-4 gap-2">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#cart-tab">Количка</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#ongoing-tab">Текущи</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#history-tab">История</button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- ================= КОЛИЧКА ================= -->
        <div class="tab-pane fade show active" id="cart-tab">

            @if (!cart.Any())
            {
                <div class="empty-state text-center">
                    <p>Количката ви е празна.</p>
                </div>
            }
            else
            {
                @foreach (var item in cart)
                {
                    <div class="cart-item-card">

                        <div class="cart-left">

                            <div class="cart-image-wrapper">
                                <img src="@item.Offer?.ImageUrl" class="cart-item-image" />
                            </div>

                            <div class="cart-info">
                                <div class="item-title">@item.Offer?.Title</div>
                                <div class="item-restaurant">@item.Offer?.Restaurant?.Name</div>

                                <div class="quantity-controls mt-2">

                                    <button type="button"
                                            class="qty-btn"
                                            onclick="updateQuantity('@item.Id','Decrease', this)">
                                        -
                                    </button>

                                    <span class="qty-number">@item.Quantity</span>

                                    <button type="button"
                                            class="qty-btn"
                                            onclick="updateQuantity('@item.Id','Increase', this)">
                                        +
                                    </button>

                                </div>
                            </div>

                        </div>

                        <div class="cart-right">

                            <div class="item-price">
                                @((item.Offer.DiscountedPrice * item.Quantity).ToString("F2")) EUR
                            </div>

                            <button type="button"
                                    class="remove-btn"
                                    onclick="removeItem('@item.Id', this)">
                                Премахни
                            </button>

                        </div>

                    </div>
                }

                <div class="checkout-panel mt-4">

                    <div class="d-flex justify-content-between mb-3">
                        <span>Общо</span>

                        <span class="fw-bold fs-5"
                              id="cartTotal"
                              data-base-total="@total.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                            @total.ToString("F2") EUR
                        </span>
                    </div>

                    <form asp-controller="Cart" asp-action="Checkout" method="post" class="checkout-form">

                        <div class="checkout-section">

                            <!-- DELIVERY TYPE -->
                            <div class="checkout-group">
                                <label class="form-label">Тип доставка</label>

                                <select name="deliveryType"
                                        class="form-select"
                                        id="deliveryTypeSelect">
                                    <option value="Pickup">Вземане от място</option>
                                    <option value="Delivery">Доставка (+2.00 EUR)</option>
                                </select>

                                <div id="addressField" style="display:none;" class="mt-3">
                                    <label class="form-label">Адрес за доставка</label>

                                    <input type="text"
                                           name="DeliveryAddress"
                                           class="form-control"
                                           maxlength="150"
                                           placeholder="Улица, номер, град..." />
                                </div>

                                <div id="deliveryInfo" class="delivery-fee-info"></div>
                            </div>


                            <!-- ORDER FOR SOMEONE -->
                            <div class="checkout-group mt-3">

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="orderForSomeone"
                                           name="IsForSomeoneElse"
                                           value="true" />

                                    <label class="form-check-label" for="orderForSomeone">
                                        Поръчка за друг човек
                                    </label>
                                </div>

                                <input type="hidden" name="IsForSomeoneElse" value="false" />

                                <div id="recipientFields" class="recipient-fields">

                                    <label class="form-label mt-3">Име на получателя:</label>

                                    <input type="text"
                                           name="RecipientFullName"
                                           class="form-control mb-3"
                                           maxlength="60"
                                           placeholder="Име и фамилия" />

                                    <label class="form-label">Телефон на получателя:</label>

                                    <input type="text"
                                           name="RecipientPhone"
                                           class="form-control"
                                           maxlength="10"
                                           inputmode="numeric"
                                           pattern="\d{10}"
                                           placeholder="08XXXXXXXX"
                                           oninput="this.value = this.value.replace(/[^0-9]/g,'').slice(0,10)" />
                                </div>

                            </div>

                        </div>

                        <button class="btn btn-primary-custom w-100 mt-4">
                            Потвърди поръчката
                        </button>

                    </form>
                </div>
            }
        </div>

        <!-- ================= ТЕКУЩИ ================= -->
        <div class="tab-pane fade" id="ongoing-tab">

            @if (!ongoing.Any())
            {
                <div class="empty-state text-center">
                    <p>Нямате активни поръчки.</p>
                </div>
            }
            else
            {
                @foreach (var o in ongoing)
                {
                    <div class="app-card mb-4">

                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-semibold">
                                Поръчка #@o.Id.ToString().Substring(0, 6)
                            </span>

                            <span class="badge bg-warning text-dark">
                                @o.Status.ToBg()
                            </span>
                        </div>

                        <div class="client-timeline modern">

                            @{
                                var steps = new List<ReservationStatus>
                                        {
                                        ReservationStatus.Pending,
                                        ReservationStatus.Confirmed,
                                        ReservationStatus.OutForDelivery,
                                        ReservationStatus.Finished
                                        };

                                if (o.Status == ReservationStatus.Canceled)
                                {
                                    steps.Add(ReservationStatus.Canceled);
                                }
                            }

                            @foreach (var step in steps)
                            {
                                if (step == ReservationStatus.OutForDelivery && o.DeliveryType != "Delivery")
                                {
                                    continue;
                                }

                                var reached = HasReachedStatus(o, step);
                                var time = GetStatusTime(o, step);

                                <div class="timeline-step @(reached ? "done" : "") @(step == ReservationStatus.Canceled ? "cancel" : "")">
                                    <div class="circle"></div>

                                    <span>@step.ToBg()</span>

                                    @if (time != null)
                                    {
                                        <small class="text-muted">@time.Value.ToLocalTime().ToString("HH:mm")</small>
                                    }
                                </div>

                                if (step != steps.Last())
                                {
                                    <div class="timeline-line @(step == ReservationStatus.Canceled ? "cancel-line" : "")"></div>
                                }
                            }
                        </div>

                        @{
                            var last = o.StatusLogs
                            .OrderByDescending(l => l.ChangedAt)
                            .FirstOrDefault();

                            var lastUpdate = last != null
                            ? last.ChangedAt.ToLocalTime()
                            : o.CreatedAt.ToLocalTime();

                            var remainingMinutes = 30 - (int)(DateTime.UtcNow - o.CreatedAt).TotalMinutes;
                        }

                        <div class="order-meta mt-2 d-flex justify-content-between small">

                            <span class="text-muted">
                                Последна промяна: @lastUpdate.ToString("g")
                            </span>

                            @if (o.Status == ReservationStatus.Pending && remainingMinutes > 0)
                            {
                                <span class="text-warning">
                                    ⏳ Остават @remainingMinutes мин
                                </span>
                            }

                        </div>

                        <div class="fw-bold mt-3">
                            Общо: @o.TotalPrice EUR
                        </div>

                    </div>
                }
            }
        </div>

        <!-- ================= ИСТОРИЯ ================= -->
        <div class="tab-pane fade" id="history-tab">

            @if (!history.Any())
            {
                <div class="empty-state text-center">
                    <p>Нямате предишни поръчки.</p>
                </div>
            }
            else
            {
                @foreach (var h in history)
                {
                    <div class="app-card mb-4">

                        <div class="d-flex justify-content-between align-items-start mb-3">

                            <div>
                                <div class="fw-semibold">
                                    Поръчка #@h.Id.ToString().Substring(0, 6)
                                </div>

                                <div class="order-date">
                                    @h.CreatedAt.ToLocalTime().ToString("dd MMM yyyy • HH:mm")
                                </div>
                            </div>

                            <span class="badge @(h.Status == ReservationStatus.Finished ? "bg-success" : "bg-danger")">
                                @h.Status.ToBg()
                            </span>

                        </div>

                        @if (h.IsForSomeoneElse)
                        {
                            <div class="small-text">
                                <strong>Получател:</strong> @h.RecipientFullName · @h.RecipientPhone
                            </div>

                            <div class="small-text text-muted">
                                Поръчано от: @h.User.FullName · @h.User.PhoneNumber
                            </div>
                        }
                        else
                        {
                            <div class="small-text">
                                @h.User.FullName · @h.User.PhoneNumber
                            </div>
                        }

                        <div class="small-text">
                            Тип доставка: @h.DeliveryType
                        </div>

                        @if (h.DeliveryType == "Delivery" && !string.IsNullOrEmpty(h.DeliveryAddress))
                        {
                            <div class="small-text">
                                Адрес: @h.DeliveryAddress
                            </div>
                        }

                        <div class="items-section mt-2">
                            @foreach (var item in h.Items)
                            {
                                <div class="item-line">
                                    @item.Offer.Title (Количество: @item.Quantity)
                                </div>
                            }
                        </div>

                        <div class="fw-bold mt-3">
                            Общо: @h.TotalPrice.ToString("F2") EUR
                        </div>

                        @if (h.Status == ReservationStatus.Finished)
                        {
                            var finishedLog = h.StatusLogs
                            .Where(l => l.NewStatus == ReservationStatus.Finished)
                            .OrderByDescending(l => l.ChangedAt)
                            .FirstOrDefault();

                            bool reviewExpired = true;

                            if (finishedLog != null)
                            {
                                reviewExpired = finishedLog.ChangedAt.AddDays(3) < DateTime.UtcNow;
                            }

                            <div class="mt-3">

                                @if (h.Review != null)
                                {
                                    <div class="review-display">

                                        <div class="review-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="star @(i <= h.Review.Rating ? "filled" : "")">★</span>
                                            }
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(h.Review.Comment))
                                        {
                                            <div class="review-comment">
                                                "@h.Review.Comment"
                                            </div>
                                        }

                                        <div class="mt-2">

                                            <a asp-controller="Reviews"
                                               asp-action="Edit"
                                               asp-route-reservationId="@h.Id"
                                               class="btn btn-sm btn-review">
                                                Редактирай
                                            </a>

                                            <form asp-controller="Reviews"
                                                  asp-action="Delete"
                                                  method="post"
                                                  style="display:inline;">
                                                <input type="hidden" name="reservationId" value="@h.Id" />
                                                <button class="btn btn-sm btn-danger">
                                                    Изтрий
                                                </button>
                                            </form>

                                        </div>

                                    </div>
                                }
                                else if (!reviewExpired)
                                {
                                    <a asp-controller="Reviews"
                                       asp-action="Create"
                                       asp-route-reservationId="@h.Id"
                                       class="btn btn-sm btn-review">
                                        Остави отзив
                                    </a>
                                }
                                else
                                {
                                    <div class="review-status expired">
                                        ⏳ Времето за ревю изтече
                                    </div>
                                }

                            </div>
                        }

                    </div>
                }
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // ====== Cart page script (NO refresh) ======
        // Requires CartController actions Increase/Decrease/Remove to return JSON:
        // { success: true, quantity: n, itemTotal: number, cartTotal: number }

        let deliveryFee = 0;

        document.addEventListener("DOMContentLoaded", function () {

            const totalEl = document.getElementById("cartTotal");
            const deliverySelect = document.getElementById("deliveryTypeSelect");
            const addressField = document.getElementById("addressField");
            const deliveryInfo = document.getElementById("deliveryInfo");
            const checkbox = document.getElementById("orderForSomeone");
            const recipientFields = document.getElementById("recipientFields");
            const checkoutForm = document.querySelector(".checkout-form");

            // nothing to do if cart tab isn't rendered
            if (!totalEl) return;

            // ------- helpers -------
            function getBaseTotal() {

                let raw = totalEl.dataset.baseTotal;

                if (!raw) {
                    raw = totalEl.textContent.replace("EUR","").trim();
            }

            const val = Number(raw);

            return isNaN(val) ? 0 : val;
        }

            function setBaseTotal(v) {
                const num = parseFloat(v);
                totalEl.dataset.baseTotal = (isNaN(num) ? 0 : num).toFixed(2);
            }

            function recalculateTotal() {
                const base = getBaseTotal();
                const final = base + deliveryFee;

                totalEl.textContent = final.toFixed(2) + " EUR";

                if (deliveryInfo) {
                    deliveryInfo.textContent = deliveryFee === 2
                        ? "+2.00 EUR delivery fee applied"
                        : "";
                }
            }

            function syncDeliveryFeeFromSelect() {
                if (!deliverySelect) {
                    deliveryFee = 0;
                    return;
                }
                deliveryFee = (deliverySelect.value === "Delivery") ? 2 : 0;
            }

            // ------- delivery address toggle -------
            if (deliverySelect && addressField) {
                deliverySelect.addEventListener("change", function () {
                    addressField.style.display = (this.value === "Delivery") ? "block" : "none";
                });

                // initial state
                addressField.style.display = (deliverySelect.value === "Delivery") ? "block" : "none";
            }

            // ------- delivery fee -------
            if (deliverySelect) {
                deliverySelect.addEventListener("change", function () {
                    syncDeliveryFeeFromSelect();
                    recalculateTotal();
                });
            }

            // initial totals
            syncDeliveryFeeFromSelect();
            recalculateTotal();

            // ------- recipient fields toggle -------
            if (checkbox && recipientFields) {
                function toggleRecipientFields() {
                    recipientFields.style.display = checkbox.checked ? "block" : "none";
                }
                checkbox.addEventListener("change", toggleRecipientFields);
                toggleRecipientFields();
            }

            // ------- prevent empty checkout -------
            if (checkoutForm) {
                checkoutForm.addEventListener("submit", function (e) {
                    const base = getBaseTotal();
                    if (base <= 0) {
                        e.preventDefault();
                        alert("Your cart is empty.");
                    }
                });
            }

            // ------- ajax quantity updates -------
            window.updateQuantity = async function (itemId, action, btn) {
                try {
                    const card = btn.closest(".cart-item-card");
                    if (!card) return;

                    const qtyEl = card.querySelector(".qty-number");
                    const priceEl = card.querySelector(".item-price");

                    const response = await fetch(`/Cart/${action}`, {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
                        body: `itemId=${encodeURIComponent(itemId)}`
                    });

                    if (!response.ok) return;

                    const data = await response.json();
                    if (!data || data.success !== true) return;

                    if (qtyEl) qtyEl.textContent = data.quantity;
                    if (priceEl) priceEl.textContent = parseFloat(data.itemTotal).toFixed(2) + " EUR";

                    setBaseTotal(data.cartTotal);
                    recalculateTotal();
                } catch (err) {
                    console.error(err);
                }
            };

            // ------- ajax remove item -------
            window.removeItem = async function (id, btn) {
                try {
                    const card = btn.closest(".cart-item-card");

                    const response = await fetch(`/Cart/Remove`, {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
                        body: `id=${encodeURIComponent(id)}`
                    });

                    if (!response.ok) return;

                    const data = await response.json();
                    if (!data || data.success !== true) return;

                    if (card) card.remove();

                    setBaseTotal(data.cartTotal);

                    // if cart is empty, also reset delivery fee UI/state
                    if (getBaseTotal() <= 0) {
                        deliveryFee = 0;
                        if (deliverySelect) deliverySelect.value = "Pickup";
                        if (addressField) addressField.style.display = "none";
                    }

                    recalculateTotal();
                } catch (err) {
                    console.error(err);
                }
            };
        });
    </script>
}