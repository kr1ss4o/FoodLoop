@model FoodLoop.Models.ViewModels.RestaurantDashboardViewModel
@using FoodLoop.Models.Enums


@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<h2 class="mb-4">@Model.RestaurantName Dashboard</h2>

<!-- DATE PICKER NAVIGATION -->

<div class="date-navigation mb-4">

    <a asp-action="Index"
       asp-route-date="@Model.SelectedDate.AddDays(-1)"
       class="date-nav-btn">
        ←
    </a>

    <form method="get" asp-action="Index" class="date-form">
        <input type="date"
               name="date"
               value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
               max="@DateTime.UtcNow.ToString("yyyy-MM-dd")"
               class="date-picker"
               onchange="this.form.submit()" />
    </form>

    @if (Model.SelectedDate < DateTime.UtcNow.Date)
    {
        <a asp-action="Index"
           asp-route-date="@Model.SelectedDate.AddDays(1)"
           class="date-nav-btn">
            →
        </a>
    }
</div>

<!-- KPI CARTS GRID -->

<div class="kpi-grid">

    <div class="kpi-card">
        <div class="kpi-title">Total Orders</div>
        <div class="kpi-value">@Model.TotalOrders</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Total Revenue</div>
        <div class="kpi-value">@Model.TotalRevenue EUR</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Orders This Week</div>
        <div class="kpi-value">@Model.OrdersThisWeek</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Revenue This Week</div>
        <div class="kpi-value">@Model.RevenueThisWeek EUR</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Avg Order Value</div>
        <div class="kpi-value">@Model.AverageOrderValue.ToString("0.00") EUR</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Pending Orders</div>
        <div class="kpi-value">@Model.PendingOrders</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Delivery Orders</div>
        <div class="kpi-value">@Model.DeliveryOrders</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Pickup Orders</div>
        <div class="kpi-value">@Model.PickupOrders</div>
    </div>

    <div class="kpi-card rating-card">
        <div class="kpi-title">Average Rating</div>
        <div class="kpi-value rating-value">
            @Model.AverageRating.ToString("0.0") ⭐
        </div>
        <small>@Model.TotalReviews reviews</small>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Cancellation Rate</div>
        <div class="kpi-value">
            @Model.CancellationRate.ToString("0.0")%
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-title">Top Offer</div>
        <div class="kpi-value">
            @Model.TopOfferTitle <br />
            <small>@Model.TopOfferSoldCount sold</small>
        </div>
    </div>

</div>

<!-- HEATMAP -->

<div class="heatmap mt-5">
    <h5>Last 30 Days Activity</h5>

    <div class="heatmap-grid">
        @for (int i = 29; i >= 0; i--)
        {
            var day = DateTime.UtcNow.Date.AddDays(-i);
            var count = Model.DailyReservations
            .Where(r => r.CreatedAt.Date == day)
            .Count();

            var level = count == 0 ? "level-0" :
            count < 3 ? "level-1" :
            count < 6 ? "level-2" :
            "level-3";

            <div class="heatmap-cell @level"
                 title="@day.ToString("dd MMM") - @count orders">
            </div>
        }
    </div>
</div>

<!-- CHART -->
<div class="chart-section mt-5 mb-4">
    <canvas id="ordersChart"></canvas>
</div>

<!-- DAILY REVENUE SUMMARY -->
@{
    var totalRevenueToday = Model.DailyReservations
        .Where(r => r.Status == ReservationStatus.Finished.ToString())
        .Sum(r => r.TotalPrice);

    var totalOrdersToday = Model.DailyReservations.Count;

    var finishedToday = Model.DailyReservations
        .Count(r => r.Status == ReservationStatus.Finished.ToString());

    var canceledToday = Model.DailyReservations
        .Count(r => r.Status == ReservationStatus.Canceled.ToString());
}
<h5>Daily revenue summary:</h5>
<div class="daily-summary mt-4 mb-4">
    <div class="summary-box">
        <div class="summary-label">Total Orders</div>
        <div class="summary-value">@totalOrdersToday</div>
    </div>

    <div class="summary-box">
        <div class="summary-label">Finished</div>
        <div class="summary-value success">@finishedToday</div>
    </div>

    <div class="summary-box">
        <div class="summary-label">Canceled</div>
        <div class="summary-value danger">@canceledToday</div>
    </div>

    <div class="summary-box">
        <div class="summary-label">Revenue</div>
        <div class="summary-value highlight">
            @totalRevenueToday.ToString("0.00") EUR
        </div>
    </div>

</div>

<!-- TABLE SORT -->
<div class="daily-orders mt-4">

    <h5>Orders for @Model.SelectedDate.ToString("dd MMM yyyy")</h5>

    @if (!Model.DailyReservations.Any())
    {
        <p>No orders for this day.</p>
    }
    else
    {
        <table id="ordersTable" class="table table-hover">
            <thead>
                <tr>
                    <th onclick="sortTable(0)">#</th>
                    <th onclick="sortTable(1)">Customer</th>
                    <th onclick="sortTable(2)">Delivery type</th>
                    <th onclick="sortTable(3)">Status</th>
                    <th onclick="sortTable(4)">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.DailyReservations)
                {
                    var rowId = "details-" + order.Id.ToString();

                    <tr class="order-row" onclick="toggleDetails('@rowId')">
                        <td>@order.Id.ToString().Substring(0, 6)</td>
                        <td>@order.CustomerName</td>
                        <td>@order.DeliveryType</td>
                        <td>
                            <span class="status-badge @order.Status.ToString().ToLower()">
                                @order.Status
                            </span>
                        </td>
                        <td>@order.TotalPrice EUR</td>
                    </tr>

                    <tr id="@rowId" class="order-details" style="display:none;">
                        <td colspan="5">
                            @foreach (var item in order.Items)
                            {
                                <div>
                                    • @item.OfferTitle × @item.Quantity
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- PEAK HOURS CHART -->
<div class="chart-section mt-4">
    <canvas id="hourChart"></canvas>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Last 7 days chart
        const ctx = document.getElementById('ordersChart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels)),
                datasets: [{
                    label: 'Orders',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartOrders)),
                    borderColor: '#00a86b',
                    backgroundColor: 'rgba(0,168,107,0.1)',
                    tension: 0.4,
                    fill: true
                }]
            }
        });

        // Sort order table 
        function toggleDetails(id) {
            const row = document.getElementById(id);
            row.style.display = row.style.display === "none" ? "table-row" : "none";
        }

        function sortTable(columnIndex) {
            const table = document.getElementById("ordersTable");
            const rows = Array.from(table.rows).slice(1);

            const sorted = rows.sort((a, b) => {
                const A = a.cells[columnIndex].innerText;
                const B = b.cells[columnIndex].innerText;
                return A.localeCompare(B, undefined, { numeric: true });
            });

            sorted.forEach(row => table.tBodies[0].appendChild(row));
        }

        // Peak hours chart 
        const hourCtx = document.getElementById('hourChart');

        new Chart(hourCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HourLabels)),
                datasets: [{
                    label: 'Orders by Hour',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HourOrders)),
                    backgroundColor: '#003b55'
                }]
            }
        });
    </script>
}