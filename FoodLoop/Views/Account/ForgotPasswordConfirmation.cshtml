@{
    ViewData["Title"] = "Reset Link Generated";
    ViewData["BodyClass"] = "auth-body";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-wrapper">
    <div class="auth-form-side">
        <div class="auth-card">

            <h2 class="auth-heading">Reset link created</h2>
            <p class="auth-desc">Use the link below to reset your password.</p>

            <div class="reset-box">
                <a href="@ViewBag.ResetLink" class="btn-primary">Reset Password</a>
            </div>

        </div>
    </div>
</div>