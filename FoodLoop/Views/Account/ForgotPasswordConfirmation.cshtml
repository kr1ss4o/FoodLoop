@{
    ViewData["Title"] = "Линк изпратен";
    ViewData["BodyClass"] = "auth-body";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<div class="auth-page">

    <div class="auth-card auth-small">

        <h2 class="auth-heading">Линкът е готов</h2>
        <p class="auth-sub">
            Натисни бутона по-долу, за да смениш паролата си.
        </p>

        <div class="auth-info">
            Линкът е валиден за ограничено време.
        </div>

        <div style="margin-top: 20px;">
            <a href="@ViewBag.ResetLink" class="btn-primary">
                Смени паролата
            </a>
        </div>

        <div class="auth-links">
            <a asp-controller="Account" asp-action="Login">
                Обратно към вход
            </a>
        </div>

    </div>

</div>