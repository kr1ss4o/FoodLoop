@model FoodLoop.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log In";
    ViewData["BodyClass"] = "auth-body";
}

<div class="auth-wrapper">
    <h1 class="auth-title">Welcome to FoodLoop</h1>

    <div class="auth-container">

        <h2 class="auth-subtitle">Log In to your profile</h2>

        <form asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <label>Email:</label>
            <input asp-for="Email" class="auth-input" />
            <span asp-validation-for="Email" class="text-danger"></span>

            <label>Password:</label>
            <input asp-for="Password" type="password" class="auth-input" />
            <span asp-validation-for="Password" class="text-danger"></span>

            <button type="submit" class="auth-btn">Log In</button>

        </form>

        <div class="auth-links">
            <a href="#">Forgotten password?</a>
            <a href="/Account/Register">Create an account now.</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}