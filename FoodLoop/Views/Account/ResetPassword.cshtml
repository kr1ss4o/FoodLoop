@model FoodLoop.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["BodyClass"] = "auth-body";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-wrapper">
    <div class="auth-form-side">
        <div class="auth-card">

            <h2 class="auth-heading">Set a new password</h2>

            <form method="post">

                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <div class="input-group">
                    <label>New password</label>
                    <input asp-for="NewPassword" type="password" />
                    <span asp-validation-for="NewPassword" class="val"></span>
                </div>

                <div class="input-group">
                    <label>Confirm password</label>
                    <input asp-for="ConfirmPassword" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="val"></span>
                </div>

                <button type="submit" class="btn-primary">Reset password</button>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}