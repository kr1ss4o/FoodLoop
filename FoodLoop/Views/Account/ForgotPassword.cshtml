@model FoodLoop.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Забравена парола";
    ViewData["BodyClass"] = "auth-body";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<div class="auth-page">

    <div class="auth-card auth-small">

        <h2 class="auth-heading">Забравена парола</h2>
        <p class="auth-sub">Ще изпратим линк за възстановяване</p>

        <form method="post">

            <div class="form-group input-modern">
                <i class="bi bi-envelope"></i>
                <input asp-for="Email" placeholder=" " required />
                <label>Имейл адрес</label>
            </div>

            <button type="submit" class="btn-primary">
                Изпрати линк
            </button>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}