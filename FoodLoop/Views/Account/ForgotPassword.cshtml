@model FoodLoop.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["BodyClass"] = "auth-body";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-wrapper">

    <div class="auth-form-side">
        <div class="auth-card">

            <h2 class="auth-heading">Reset your password</h2>
            <p class="auth-desc">Enter your email to receive a reset link.</p>

            <form method="post">

                <div class="input-group">
                    <label>Email</label>
                    <input asp-for="Email" />
                    <span asp-validation-for="Email" class="val"></span>
                </div>

                <button type="submit" class="btn-primary">Send reset link</button>
            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}