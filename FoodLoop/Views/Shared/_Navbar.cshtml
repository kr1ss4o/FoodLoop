@using Microsoft.AspNetCore.Identity
@using FoodLoop.Models.Entities

@inject UserManager<User> UserManager

@{
    /* =====================================================
       GET CURRENT USER (ASYNC SAFE)
    ===================================================== */

    User? user = await UserManager.GetUserAsync(User);

    string currentPath = Context.Request.Path.Value?.ToLower() ?? "";

    string role = "Client";

    if (user != null)
    {
        var roles = await UserManager.GetRolesAsync(user);
        role = roles.FirstOrDefault() ?? "Client";
    }

    bool isBusiness = role == "Restaurant";

    /* =====================================================
       ACTIVE PAGE DETECTION
    ===================================================== */

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    bool isProfileActive =
        controller == "Profile" ||
        controller == "BusinessProfile";

    bool isCartActive =
        controller == "Orders";

    bool isOrderManagerActive =
        controller == "OrderManager";

    bool isOfferManagerActive =
        controller == "OfferManager";
}

<nav class="navbar navbar-expand-lg app-navbar">

    <div class="container-fluid">

        <!-- =====================================================
             LOGO / BRAND
        ===================================================== -->

        <a class="navbar-brand fw-bold text-success" href="/">
            <i class="bi bi-leaf-fill"></i> FoodLoop
        </a>

        <!-- MOBILE TOGGLER -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- =====================================================
             NAV LINKS
        ===================================================== -->

        <div class="collapse navbar-collapse" id="mainNavbar">

            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">

                @if (!isBusiness)
                {
                    <!-- CLIENT LINKS -->

                    <li class="nav-item position-relative">

                        <a asp-controller="Cart"
                           asp-action="Index"
                           class="nav-link"
                           id="cartLink">

                            <i class="bi bi-bag"></i> Cart

                            <span id="cartBadge"
                                  class="badge bg-success ms-1 d-none">0</span>
                        </a>

                        <div id="miniCartDropdown" class="mini-cart d-none">
                            <div id="miniCartContent">
                                Loading...
                            </div>

                            <a asp-controller="Cart"
                               asp-action="Index"
                               class="mini-cart-btn">
                                Go to cart
                            </a>
                        </div>

                    </li>

                    <li class="nav-item">
                        <a asp-controller="Offers"
                           asp-action="Index"
                           class="nav-link">
                            <i class="bi bi-shop"></i> Browse
                        </a>
                    </li>

                }
                else
                {
                    <!-- BUSINESS LINKS -->

                    <li class="nav-item">
                        <a asp-controller="OrderManager"
                           asp-action="Index"
                           class="nav-link @(isOrderManagerActive ? "active fw-semibold" : "")">

                            <i class="bi bi-receipt"></i> Orders

                            <span id="cartBadge"
                                  class="badge bg-success ms-1 @(ViewBag.CartCount > 0 ? "" : "d-none")">
                                @(ViewBag.CartCount ?? 0)
                            </span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-controller="OfferManager"
                           asp-action="Index"
                           class="nav-link @(isOfferManagerActive ? "active fw-semibold" : "")">

                            <i class="bi bi-megaphone"></i> Offers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="RestaurantDashboard"
                           asp-action="Index"
                           class="nav-link @(controller == "RestaurantDashboard" ? "active fw-semibold" : "")">
                            <i class="bi bi-graph-up"></i> Dashboard
                        </a>
                    </li>
                }

                <!-- PROFILE -->

                <li class="nav-item">
                    @if (isBusiness)
                    {
                        <a asp-controller="BusinessProfile"
                           asp-action="Index"
                           class="nav-link @(isProfileActive ? "active fw-semibold" : "")">
                            <i class="bi bi-person-circle"></i> Profile
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Profile"
                           asp-action="Index"
                           class="nav-link @(isProfileActive ? "active fw-semibold" : "")">
                            <i class="bi bi-person-circle"></i> Profile
                        </a>
                    }
                </li>

                <!-- LOGOUT -->

                <li class="nav-item">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-link border-0 bg-transparent">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                </li>

            </ul>

        </div>
    </div>

</nav>