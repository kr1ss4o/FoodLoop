@using Microsoft.AspNetCore.Identity
@using FoodLoop.Models.Entities

@inject UserManager<User> UserManager

@{
    /* =====================================================
    GET CURRENT USER (ASYNC SAFE)
    ===================================================== */

    User? user = await UserManager.GetUserAsync(User);

    string currentPath = Context.Request.Path.Value?.ToLower() ?? "";

    string role = "Client";

    if (user != null)
    {
        var roles = await UserManager.GetRolesAsync(user);
        role = roles.FirstOrDefault() ?? "Client";
    }

    bool isAdmin = role == "Admin";
    bool isBusiness = role == "Restaurant" && !isAdmin;

    /* =====================================================
       ACTIVE PAGE DETECTION
    ===================================================== */

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    bool isProfileActive =
        controller == "Profile" ||
        controller == "BusinessProfile";

    bool isCartActive =
        controller == "Orders";

    bool isOrderManagerActive =
        controller == "OrderManager";

    bool isOfferManagerActive =
        controller == "OfferManager";
}

<nav class="navbar navbar-expand-lg app-navbar fixed-top">

    <div class="container-fluid navbar-wrap">

        <!-- LOGO -->

        <a class="navbar-brand" href="/">
            <i class="bi bi-leaf-fill"></i>
            FoodLoop
        </a>


        <!-- SEARCH -->

        <form asp-controller="Search"
              asp-action="Index"
              method="get"
              class="navbar-search">

            <i class="bi bi-search"></i>

            <input type="text"
                   name="query"
                   placeholder="Търси ресторант или оферта..."
                   autocomplete="off" />

        </form>


        <!-- MOBILE -->

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNavbar">

            <span class="navbar-toggler-icon"></span>

        </button>


        <!-- RIGHT SIDE -->

        <div class="collapse navbar-collapse" id="mainNavbar">

            <ul class="navbar-nav ms-auto align-items-center navbar-actions">


                <!-- OFFERS -->

                <li class="nav-item">

                    <a asp-controller="Offers"
                           asp-action="Index"
                           class="nav-main-btn">

                        <i class="bi bi-tag"></i>

                        <span>Оферти</span>

                    </a>

                </li>


                <!-- RESTAURANTS -->

                <li class="nav-item">

                    <a asp-controller="Restaurant"
                           asp-action="Index"
                           class="nav-main-btn">

                        <i class="bi bi-shop"></i>

                        <span>Търговци</span>

                    </a>

                </li>


                <!-- CART -->

                <li class="nav-item position-relative">

                    <a asp-controller="Cart"
                           asp-action="Index"
                           class="nav-icon-btn"
                           id="cartLink">

                        <i class="bi bi-bag"></i>

                        <span id="cartBadge"
                              class="cart-badge d-none">0</span>

                    </a>

                    <div id="miniCartDropdown"
                         class="mini-cart d-none">

                        <div id="miniCartContent">
                            Loading...
                        </div>

                    </div>

                </li>


                <!-- PROFILE -->

                <li class="nav-item">

                    <a asp-controller="Profile"
                           asp-action="Index"
                           class="nav-icon-btn">

                        <i class="bi bi-person-circle"></i>

                    </a>

                </li>


            </ul>

        </div>

    </div>

</nav>
<script>

    // Nav bar shadow on scroll

        window.addEventListener("scroll", () => {

        const nav = document.querySelector(".app-navbar");

        if(window.scrollY > 10)
            nav.classList.add("scrolled");
        else
            nav.classList.remove("scrolled");

    });
</script>