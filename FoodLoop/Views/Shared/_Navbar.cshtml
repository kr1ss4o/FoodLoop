@using Microsoft.AspNetCore.Identity
@using FoodLoop.Models.Entities

@inject UserManager<User> UserManager

@{
    User? user = await UserManager.GetUserAsync(User);

    string role = "Client";

    if (user != null)
    {
        var roles = await UserManager.GetRolesAsync(user);
        role = roles.FirstOrDefault() ?? "Client";
    }

    bool isAdmin = role == "Admin";
    bool isBusiness = role == "Restaurant" && !isAdmin;

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    bool isProfileActive =
        controller == "Profile" ||
        controller == "BusinessProfile";

    bool isOrderManagerActive =
        controller == "OrderManager";

    bool isOfferManagerActive =
        controller == "OfferManager";
}

<nav class="navbar navbar-expand-lg app-navbar fixed-top">

    <div class="container-fluid navbar-layout">

        <!-- BRAND -->

        <a class="navbar-brand fw-bold text-success" href="/">
            <i class="bi bi-leaf-fill"></i> FoodLoop
        </a>


        <!-- SEARCH -->

        <form asp-controller="Search"
              asp-action="Index"
              method="get"
              class="navbar-search">

            <i class="bi bi-search"></i>

            <input type="text"
                   name="query"
                   placeholder="Търси ресторант или оферта..." />

        </form>


        <!-- MOBILE -->

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNavbar">

            <span class="navbar-toggler-icon"></span>

        </button>


        <div class="collapse navbar-collapse justify-content-end"
             id="mainNavbar">

            <ul class="navbar-nav align-items-center gap-lg-3">


                <!-- OFFERS -->

                <li class="nav-item">

                    <a asp-controller="Offers"
                           asp-action="Index"
                           class="nav-link">

                        <i class="bi bi-tag"></i>
                        Оферти

                    </a>

                </li>


                @{
                    if (isAdmin)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock"></i> Админ
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminDashboard"
                                       asp-action="Index">Табло</a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminCategories"
                                       asp-action="Categories">Категории</a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminTags"
                                       asp-action="Tags">Тагове</a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminRestaurants"
                                       asp-action="Restaurants">Ресторанти</a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminOffers"
                                       asp-action="Offers">Оферти</a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminReservations"
                                       asp-action="Reservations">Поръчки</a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminReviews"
                                       asp-action="Reviews">Ревюта</a>
                                </li>

                            </ul>
                        </li>
                    }
                    else if (isBusiness)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                                   data-bs-toggle="dropdown">

                                <i class="bi bi-shop-window"></i> Бизнес

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>
                                    <a class="dropdown-item"
                                           asp-controller="RestaurantDashboard"
                                           asp-action="Index">

                                        <i class="bi bi-graph-up-arrow me-2"></i>
                                        Статистика

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item d-flex justify-content-between align-items-center"
                                           asp-controller="OrderManager"
                                           asp-action="Index">

                                        <span>
                                            <i class="bi bi-receipt-cutoff me-2"></i>
                                            Поръчки
                                        </span>

                                        <span id="cartBadge"
                                              class="badge bg-success @(ViewBag.CartCount > 0 ? "" : "d-none")">

                                            @(ViewBag.CartCount ?? 0)

                                        </span>

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                           asp-controller="OfferManager"
                                           asp-action="Index">

                                        <i class="bi bi-megaphone me-2"></i>
                                        Моите оферти

                                    </a>
                                </li>

                            </ul>

                        </li>
                    }
                    else
                    {
                        <li class="nav-item">

                            <a asp-controller="Restaurant"
                                   asp-action="Index"
                                   class="nav-link">

                                <i class="bi bi-shop"></i>
                                Търговци

                            </a>

                        </li>

                        <li class="nav-item position-relative">

                            <a asp-controller="Cart"
                                   asp-action="Index"
                                   class="nav-icon-btn"
                                   id="cartLink">

                                <i class="bi bi-bag"></i>

                                <span id="cartBadge"
                                      class="cart-badge d-none">0</span>

                            </a>

                            <div id="miniCartDropdown" class="mini-cart d-none">
                                <div id="miniCartContent">Loading...</div>
                            </div>

                        </li>
                    }
                }



                <!-- PROFILE -->

                <li class="nav-item">

                    @if (isBusiness)
                    {
                        <a asp-controller="BusinessProfile"
                               asp-action="Index"
                               class="nav-icon-btn">

                            <i class="bi bi-person-circle"></i>

                        </a>
                    }
                    else
                    {
                        <a asp-controller="Profile"
                               asp-action="Index"
                               class="nav-icon-btn">

                            <i class="bi bi-person-circle"></i>

                        </a>
                    }

                </li>


                <!-- LOGOUT -->

                <li class="nav-item">

                    <form asp-controller="Account"
                          asp-action="Logout"
                          method="post"
                          class="d-inline">

                        <button type="submit"
                                class="nav-icon-btn logout-btn">

                            <i class="bi bi-box-arrow-right"></i>

                        </button>

                    </form>

                </li>


            </ul>

        </div>

    </div>

</nav>