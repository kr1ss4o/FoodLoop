@using Microsoft.AspNetCore.Identity
@using FoodLoop.Models.Entities

@inject UserManager<User> UserManager

@{
    /* =====================================================
    GET CURRENT USER (ASYNC SAFE)
    ===================================================== */

    User? user = await UserManager.GetUserAsync(User);

    string currentPath = Context.Request.Path.Value?.ToLower() ?? "";

    string role = "Client";

    if (user != null)
    {
        var roles = await UserManager.GetRolesAsync(user);
        role = roles.FirstOrDefault() ?? "Client";
    }

    bool isAdmin = role == "Admin";
    bool isBusiness = role == "Restaurant" && !isAdmin;

    /* =====================================================
       ACTIVE PAGE DETECTION
    ===================================================== */

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    bool isProfileActive =
        controller == "Profile" ||
        controller == "BusinessProfile";

    bool isCartActive =
        controller == "Orders";

    bool isOrderManagerActive =
        controller == "OrderManager";

    bool isOfferManagerActive =
        controller == "OfferManager";
}

<nav class="navbar navbar-expand-lg app-navbar">

    <div class="container-fluid">

        <!-- =====================================================
             LOGO / BRAND
        ===================================================== -->

        <a class="navbar-brand fw-bold text-success" href="/">
            <i class="bi bi-leaf-fill"></i> FoodLoop
        </a>

        <!-- MOBILE TOGGLER -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- =====================================================
             NAV LINKS
        ===================================================== -->

        <div class="collapse navbar-collapse" id="mainNavbar">

            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                
                <!-- MARKETPLACE (OFFERS) -->

                <li class="nav-item">
                    <a asp-controller="Offers"
                       asp-action="Index"
                       class="nav-link">
                        <i class="bi bi-shop"></i>
                         Оферти
                    </a>
                </li>

                @if (isAdmin)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown">

                            <i class="bi bi-shield-lock"></i> Администратор
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminDashboard"
                                   asp-action="Index">
                                    Табло
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminCategories"
                                   asp-action="Categories">
                                    Категории
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                    asp-controller="AdminTags"
                                    asp-action="Tags">
                                    Тагове
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminRestaurants"
                                   asp-action="Restaurants">
                                    Ресторанти
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminOffers"
                                   asp-action="Offers">
                                    Оферти
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminReservations"
                                   asp-action="Reservations">
                                    Поръчки
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminReviews"
                                   asp-action="Reviews">
                                    Ревюта
                                </a>
                            </li>

                        </ul>
                    </li>
                }
                else if (isBusiness)
                {
                    <li class="nav-item dropdown">

                        <a class="nav-link dropdown-toggle @(isOrderManagerActive || isOfferManagerActive || controller == "RestaurantDashboard" ? "active fw-semibold" : "")"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown">

                            <i class="bi bi-shop-window"></i> Бизнес панел
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="RestaurantDashboard"
                                   asp-action="Index">

                                    <i class="bi bi-graph-up-arrow me-2"></i>
                                    Статистика

                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item d-flex justify-content-between align-items-center"
                                   asp-controller="OrderManager"
                                   asp-action="Index">

                                    <span>
                                        <i class="bi bi-receipt-cutoff me-2"></i>
                                        Поръчки
                                    </span>

                                    <span id="cartBadge"
                                          class="badge bg-success @(ViewBag.CartCount > 0 ? "" : "d-none")">
                                        @(ViewBag.CartCount ?? 0)
                                    </span>

                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="OfferManager"
                                   asp-action="Index">

                                    <i class="bi bi-megaphone me-2"></i>
                                    Моите оферти

                                </a>
                            </li>

                        </ul>

                    </li>
                }
                else // Client nav-bar
                {
                    <li class="nav-item position-relative">

                        <a asp-controller="Cart"
                           asp-action="Index"
                           class="nav-link"
                           id="cartLink">

                            <i class="bi bi-bag"></i> Количка

                            <span id="cartBadge"
                                  class="badge bg-success ms-1 d-none">0</span>
                        </a>

                        <div id="miniCartDropdown" class="mini-cart d-none">
                            <div id="miniCartContent">
                                Loading...
                            </div>

                            <a asp-controller="Cart"
                               asp-action="Index"
                               class="mini-cart-btn">
                                Go to cart
                            </a>
                        </div>

                    </li>

                    <li class="nav-item">
                        <a asp-controller="Restaurant"
                           asp-action="Index"
                           class="nav-link">
                            <i class="bi bi-shop"></i>
                            Търговци
                        </a>
                    </li>
                }

                <!-- PROFILE -->

                <li class="nav-item">
                    @if (isBusiness)
                    {
                        <a asp-controller="BusinessProfile"
                           asp-action="Index"
                           class="nav-link @(isProfileActive ? "active fw-semibold" : "")">
                            <i class="bi bi-person-circle"></i> Профил
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Profile"
                           asp-action="Index"
                           class="nav-link @(isProfileActive ? "active fw-semibold" : "")">
                            <i class="bi bi-person-circle"></i> Профил
                        </a>
                    }
                </li>

                <!-- LOGOUT -->

                <li class="nav-item">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-link border-0 bg-transparent">
                            <i class="bi bi-box-arrow-right"></i> Изход
                        </button>
                    </form>
                </li>

            </ul>

        </div>
    </div>

</nav>