@model FoodLoop.Models.ViewModels.PaginationViewModel

@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <!-- PREVIOUS -->
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="@Model.Action"
                   asp-controller="@Model.Controller"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-query="@Model.Query"
                   asp-route-sort="@Model.Sort"
                   asp-route-categoryId="@Model.CategoryId"
                   asp-route-section="@Model.Section">
                    «
                </a>
            </li>

            @{
                int start = Math.Max(1, Model.CurrentPage - 2);
                int end = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
            }

            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link"
                       asp-action="@Model.Action"
                       asp-controller="@Model.Controller"
                       asp-route-page="@i"
                       asp-route-query="@Model.Query"
                       asp-route-sort="@Model.Sort"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-section="@Model.Section">
                        @i
                    </a>
                </li>
            }

            <!-- NEXT -->
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="@Model.Action"
                   asp-controller="@Model.Controller"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-query="@Model.Query"
                   asp-route-sort="@Model.Sort"
                   asp-route-categoryId="@Model.CategoryId"
                   asp-route-section="@Model.Section">
                    »
                </a>
            </li>

        </ul>
    </nav>
}