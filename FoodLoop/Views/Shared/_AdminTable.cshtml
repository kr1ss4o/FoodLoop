@using System.Reflection
@using System.ComponentModel.DataAnnotations;
@model IEnumerable<object>

@{
    var items = Model?.Cast<object>().ToList();

    if (items == null || !items.Any())
    {
        <p>No data available.</p>
        return;
    }

    var type = items.First().GetType();
    var hiddenColumns = new[]
    {
        "IconUrl",
        "ImageUrl",
        "BannerImageUrl",
        "OwnerUserId",
        "RestaurantId",
        "CategoryId",
        "UserId",
        "IsLowStock"
    };

    var props = type.GetProperties()
        .Where(p =>
            p.GetCustomAttribute<DisplayAttribute>() != null &&
            !hiddenColumns.Contains(p.Name))
        .ToList();
}

<table class="admin-table">

    <thead>
        <tr>

            @foreach (var prop in props)
            {
                var display = prop.GetCustomAttribute<DisplayAttribute>();
                var name = display?.Name ?? prop.Name;

                <th>@name</th>
            }

            <th>Actions</th>

        </tr>
    </thead>

    <tbody>

        @foreach (var item in items)
        {
            <tr>

                @foreach (var prop in props)
                {
                    var value = prop.GetValue(item);

                    if (value is DateTime dt)
                    {
                        <td>@dt.ToString("dd.MM.yyyy HH:mm")</td>
                    }
                    else if (value != null && !value.GetType().IsPrimitive && value is not string)
                    {
                        <td>-</td>
                    }
                    else
                    {
                        <td>@(value ?? "-")</td>
                    }
                }

                @{
                    var idProp = type.GetProperty("Id");
                    var id = idProp?.GetValue(item);
                }

                <td class="admin-actions">

                    @if (type.Name != "Category" && type.Name != "Tag")
                    {
                        <a asp-action="Details"
                           asp-route-id="@id"
                           class="admin-mini-btn"
                           title="Details">

                            <i class="bi bi-eye"></i>

                        </a>
                    }

                    @if (type.Name != "Review" && type.Name != "Reservation")
                    {
                        <a asp-action="Edit"
                           asp-route-id="@id"
                           class="admin-mini-btn"
                           title="Edit">

                            <i class="bi bi-pencil"></i>

                        </a>

                    }
                    @if (type.Name != "Review")
                    {
                        <form asp-action="Delete"
                              asp-route-id="@id"
                              method="post"
                              style="display:inline">

                            <button class="admin-mini-btn admin-mini-btn--danger"
                                    title="Delete">

                                <i class="bi bi-trash"></i>

                            </button>

                        </form>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>