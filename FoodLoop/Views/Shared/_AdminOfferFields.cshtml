@model FoodLoop.ViewModels.Admin.AdminFormViewModel
@using FoodLoop.Models.Entities
@using System.Linq

<h3 class="admin-section-title">Информация за оферта</h3>

<div class="admin-form-grid">

    <div class="admin-field">
        <label>Заглавие</label>

        <input asp-for="Title"
               class="admin-input"
               required
               minlength="3"
               maxlength="120" />

        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="admin-field">
        <label>Оригинална цена</label>

        <input asp-for="OriginalPrice"
               type="number"
               step="0.01"
               min="0.01"
               class="admin-input"
               required />

        <span asp-validation-for="OriginalPrice" class="text-danger"></span>
    </div>

    <div class="admin-field">
        <label>Намалена цена</label>

        <input asp-for="DiscountedPrice"
               type="number"
               step="0.01"
               min="0.01"
               class="admin-input"
               required />

        <span asp-validation-for="DiscountedPrice" class="text-danger"></span>
    </div>

    <div class="admin-field">
        <label>Количество</label>

        <input asp-for="QuantityAvailable"
               type="number"
               min="1"
               class="admin-input"
               required />

        <span asp-validation-for="QuantityAvailable" class="text-danger"></span>
    </div>

    <div class="admin-field">
        <label>Крайна дата</label>

        <input asp-for="EndsAt"
               type="datetime-local"
               class="admin-input"
               required />

        <span asp-validation-for="EndsAt" class="text-danger"></span>
    </div>

    <!-- RESTAURANT -->

    <div class="admin-field">

        <label>Ресторант</label>

        <select asp-for="RestaurantId"
                asp-items="@(new SelectList(Model.Restaurants ?? Enumerable.Empty<Restaurant>(), "Id", "Name"))"
                class="admin-input"
                required>

            <option value="">Избери ресторант</option>

        </select>

        <span asp-validation-for="RestaurantId" class="text-danger"></span>

    </div>

    <!-- CATEGORY -->

    <div class="admin-field">

        <label>Категория</label>

        <select asp-for="CategoryId"
                asp-items="@(new SelectList(Model.Categories ?? Enumerable.Empty<Category>(), "Id", "Name"))"
                class="admin-input"
                required>

            <option value="">Избери категория</option>

        </select>

        <span asp-validation-for="CategoryId" class="text-danger"></span>

    </div>

</div>

<h3 class="admin-section-title">Описание</h3>

<div class="admin-field">

    <textarea asp-for="Description"
              class="admin-input"
              required
              minlength="10"></textarea>

    <span asp-validation-for="Description" class="text-danger"></span>

</div>


<h3 class="admin-section-title">Изображение</h3>

<div class="admin-upload admin-upload-full">

    <div class="drop-zone @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "" : "preview")"
         style="background-image:url('@Model.ImageUrl')">

        <span>Плъзни изображение</span>

        <input type="file"
               name="ImageUpload"
               accept="image/*">

    </div>

    <div class="admin-field">

        <label>Или URL</label>

        <input asp-for="ImageUrl"
               type="url"
               class="admin-input admin-url-input"
               placeholder="https://example.com/offer.png" />

    </div>

</div>