@model FoodLoop.Models.ViewModels.PaginationViewModel

@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="offers-pagination">

            <!-- PREVIOUS -->
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link prev-next"
                       asp-action="@Model.Action"
                       asp-controller="@Model.Controller"
                       asp-route-query="@Model.Query"
                       asp-route-sort="@Model.Sort"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-offersPage="@(Model.Section == "offers" ? Model.CurrentPage - 1 : 1)"
                       asp-route-restaurantsPage="@(Model.Section == "restaurants" ? Model.CurrentPage - 1 : 1)">
                    ‹
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == 1 || i == Model.TotalPages ||
                    (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                {
                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                        <a class="page-link"
                               asp-action="@Model.Action"
                               asp-controller="@Model.Controller"
                               asp-route-query="@Model.Query"
                               asp-route-sort="@Model.Sort"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-offersPage="@(Model.Section == "offers" ? i : 1)"
                               asp-route-restaurantsPage="@(Model.Section == "restaurants" ? i : 1)">
                            @i
                        </a>
                    </li>
                }
                else if (i == Model.CurrentPage - 2 || i == Model.CurrentPage + 2)
                {
                    <li class="page-item page-dots">
                        <div class="page-input-wrap">
                            <input type="number"
                                   class="page-input search-page-input"
                                   placeholder="..."
                                   min="1"
                                   max="@Model.TotalPages"
                                   data-section="@Model.Section"
                                   data-action="@Model.Action"
                                   data-controller="@Model.Controller"
                                   data-query="@Model.Query"
                                   data-sort="@Model.Sort"
                                   data-category="@Model.CategoryId" />
                        </div>
                    </li>
                }
            }

            <!-- NEXT -->
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link prev-next"
                       asp-action="@Model.Action"
                       asp-controller="@Model.Controller"
                       asp-route-query="@Model.Query"
                       asp-route-sort="@Model.Sort"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-offersPage="@(Model.Section == "offers" ? Model.CurrentPage + 1 : 1)"
                       asp-route-restaurantsPage="@(Model.Section == "restaurants" ? Model.CurrentPage + 1 : 1)">
                    ›
                </a>
            </li>

        </ul>
    </nav>

    <script>
        document.addEventListener("keydown", function (e) {
            if (e.key === "Enter" && e.target.classList.contains("search-page-input")) {
                const page = parseInt(e.target.value);
                const max = parseInt(e.target.max);

                if (page >= 1 && page <= max) {
                    const section = e.target.dataset.section;
                    const action = e.target.dataset.action;
                    const controller = e.target.dataset.controller;
                    const query = e.target.dataset.query ?? "";
                    const sort = e.target.dataset.sort ?? "";
                    const category = e.target.dataset.category ?? "";

                    let url = `/${controller}/${action}?query=${query}&sort=${sort}`;
                    if (category) url += `&categoryId=${category}`;
                    if (section === "offers") url += `&offersPage=${page}&restaurantsPage=1`;
                    if (section === "restaurants") url += `&offersPage=1&restaurantsPage=${page}`;

                    window.location.href = url;
                } else {
                    e.target.value = "";
                }
            }
        });
    </script>
}
