@using FoodLoop.Models.Enums
@using FoodLoop.Helpers
@model FoodLoop.Models.Entities.Reservation

<div class="order-card">

    <div class="order-card-header">

        <div class="order-left">

            <div class="order-id">
                Поръчка #@Model.Id.ToString().Substring(0, 6)
            </div>

            <div class="order-date">
                @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy • HH:mm")
            </div>

            @if (Model.IsForSomeoneElse)
            {
                <div class="order-meta-line">
                    <strong>Получател:</strong>
                    @Model.RecipientFullName · @Model.RecipientPhone
                </div>

                <div class="order-meta-line muted">
                    Поръчана от: @Model.User.FullName
                </div>
            }
            else
            {
                <div class="order-meta-line">
                    @Model.User.FullName · @Model.User.PhoneNumber
                </div>
            }

            <div class="order-meta-line">
                <strong>Вид доставка:</strong> @Model.DeliveryType
            </div>

            @if (Model.DeliveryType == "Delivery" && !string.IsNullOrEmpty(Model.DeliveryAddress))
            {
                <div class="order-meta-line">
                    <strong>Адрес:</strong> @Model.DeliveryAddress
                </div>
            }

        </div>

        <div class="order-right">
            <span class="status-badge @GetStatusClass(Model.Status)">
                @Model.Status.GetDisplayName()

                <!-- EXPIRATION BADGE -->

                @if (Model.Status == ReservationStatus.Pending)
                {
                    var expiresAt = DateTime.SpecifyKind(
                    Model.CreatedAt,
                    DateTimeKind.Utc
                    ).AddMinutes(30);

                    <span class="pending-countdown"
                          data-expires="@expiresAt.ToString("yyyy-MM-ddTHH:mm:ssZ")">
                        00:00
                    </span>
                }
            </span>
        </div>

    </div>

    <div class="order-items">
        @foreach (var item in Model.Items)
        {
            <div class="order-item">
                <span>@item.Offer.Title</span>
                <span class="qty">Количество: @item.Quantity бр.</span>
            </div>
        }
    </div>

    <div class="order-card-footer">

        <div class="order-total">
            Обща сума: @Model.TotalPrice EUR
        </div>

        <div class="actions">

            @* PENDING *@
            @if (Model.Status == ReservationStatus.Pending)
            {
                <form asp-action="Confirm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn-action confirm-btn">
                        Потвърди
                    </button>
                </form>

                <form asp-action="Cancel" method="post" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn-action cancel-btn">
                        Откажи
                    </button>
                </form>
            }

            @* CONFIRMED *@
            @if (Model.Status == ReservationStatus.Confirmed)
            {
                if (Model.DeliveryType.Equals("Delivery", StringComparison.OrdinalIgnoreCase))
                {
                    <!-- Delivery order - only Send + Cancel -->
                    <form asp-action="OutForDelivery" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-action delivery-btn">
                            Изпрати
                        </button>
                    </form>

                    <form asp-action="Cancel" method="post" class="d-inline ms-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-action cancel-btn">
                            Откажи
                        </button>
                    </form>
                }
                else
                {
                    <!-- Pickup order -->
                    <form asp-action="Finish" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-action finish-btn">
                            Завърши
                        </button>
                    </form>

                    <form asp-action="Cancel" method="post" class="d-inline ms-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-action cancel-btn">
                            Откажи
                        </button>
                    </form>
                }
            }

            @if (Model.Status == ReservationStatus.OutForDelivery)
            {
                <!-- Only Finish -->
                <form asp-action="Finish" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn-action finish-btn">
                        Завърши
                    </button>
                </form>
            }

        </div>

    </div>

</div>

@functions {
    private string GetStatusClass(ReservationStatus status)
    {
        return status switch
        {
            ReservationStatus.Pending => "pending",
            ReservationStatus.Confirmed => "confirmed",
            ReservationStatus.OutForDelivery => "outfordelivery",
            ReservationStatus.Finished => "finished",
            ReservationStatus.Canceled => "canceled",
            _ => ""
        };
    }
}