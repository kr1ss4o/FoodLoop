@using Microsoft.AspNetCore.Identity
@using FoodLoop.Models.Entities

@inject UserManager<User> UserManager

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    bool isLogged = User?.Identity?.IsAuthenticated ?? false;

    bool hideUI =
        controller == "Account" &&
        (action == "Login" || action == "Register");
}

<!DOCTYPE html>
<html lang="en">
<head>

    <!-- META -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodLoop</title>

    <!-- BOOTSTRAP -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ICONS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- GLOBAL STYLES -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FoodLoop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <link rel="stylesheet" href="~/css/edit-profile-modal.css" />

    <!-- Special admin design -->
    @if (User.IsInRole("Admin"))
    {
        <link rel="stylesheet" href="~/css/admin.css" />
    }

</head>

<body class="@ViewData["BodyClass"]">

    @if (!hideUI)
    {
        @await Html.PartialAsync("_Navbar")
    }

    <div class="container py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- GLOBAL TOAST -->
    <div id="toast-container"></div>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/toast.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Success"])), "success");
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Error"])), "error");
        </script>
    }

    @if (TempData["Warning"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Warning"])), "warning");
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>showToast("@TempData["Info"]", "info");</script>
    }
</body>
</html>