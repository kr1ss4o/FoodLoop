@using Microsoft.AspNetCore.Identity
@using FoodLoop.Models.Entities

@inject UserManager<User> UserManager

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    bool isLogged = User?.Identity?.IsAuthenticated ?? false;

    bool hideUI =
    controller == "Account" &&
    (action == "Login"
     || action == "Register"
     || action == "ForgotPassword"
     || action == "ResetPassword");

    // Footer only appears in public pages
    bool hideFooter =
    controller == "Cart" ||
    controller == "Profile" ||
    controller == "BusinessProfile" ||
    controller == "OrderManager" ||
    controller == "OfferManager" ||
    controller == "RestaurantDashboard" ||
    controller == "AdminDashboard" ||
    controller == "AdminCategories" ||
    controller == "AdminTags" ||
    controller == "AdminRestaurants" ||
    controller == "AdminOffers" ||
    controller == "AdminReservations" ||
    controller == "AdminReviews";

}

<!DOCTYPE html>
<html lang="en">
<head>

    <!-- META -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodLoop</title>

    <!-- BOOTSTRAP -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ICONS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- GLOBAL STYLES -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FoodLoop.styles.css" asp-append-version="true" />

    <!-- Design for login / register -->
    <link rel="stylesheet" href="~/css/auth.css" />

    <!-- Design for the edit profile modal -->
    <link rel="stylesheet" href="~/css/edit-profile-modal.css" />

    <!-- Special admin design -->
    @if (User.IsInRole("Admin"))
    {
        // Design for the whole admin panel
        <link rel="stylesheet" href="~/css/admin.css" />
    }

</head>

<body class="@ViewData["BodyClass"]">

    @if (!hideUI)
    {
        @await Html.PartialAsync("_Navbar")
    }

    <!-- Validation for full width instead of side margin -->
    @if (ViewData["FullWidth"] as bool? == true)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container py-4">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    }

    <!-- GLOBAL TOAST -->
    <div id="toast-container"></div>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
     <script src="~/js/toast.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Success"])), "success");
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Error"])), "error");
        </script>
    }

    @if (TempData["Warning"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Warning"])), "warning");
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            showToast(@Html.Raw(Json.Serialize(TempData["Info"])), "info");
        </script>
    }
    
    <!-- Footer only appears in public pages -->
    @if (!hideFooter)
    {
        <footer class="site-footer">

            <div class="footer-wrapper">

                <!-- BRAND -->
                <div class="footer-col footer-brand">
                    <div class="footer-logo">
                        <span>FoodLoop</span>
                    </div>

                    <p>
                        Спасваме храна, подкрепяме ресторантите
                        и предлагаме вкусни ястия на по-достъпни цени.
                    </p>
                </div>

                <!-- QUICK LINKS -->
                <div class="footer-col">
                    <h4>Бързи връзки</h4>

                    <a asp-controller="Home" asp-action="Index">Начало</a>
                    <a asp-controller="Restaurant" asp-action="Index">Ресторанти</a>
                    <a asp-controller="Offers" asp-action="Index">Оферти</a>
                    <a asp-controller="Search" asp-action="Index">Търсене</a>
                </div>

                <!-- 🔥 DYNAMIC ACCOUNT / BUSINESS -->
                <div class="footer-col footer-account">

                    @if (User.IsInRole("Restaurant"))
                    {
                        <h4>Моят бизнес</h4>

                        <a asp-controller="RestaurantDashboard" asp-action="Index">Табло</a>
                        <a asp-controller="OfferManager" asp-action="Index">Моите оферти</a>
                        <a asp-controller="OrderManager" asp-action="Index">Поръчки</a>
                        <a asp-controller="RestaurantReviews" asp-action="Index">Ревюта</a>
                    }
                    else
                    {
                        <h4>Акаунт</h4>

                        <a asp-controller="Cart" asp-action="Index">Количка</a>
                        <a asp-controller="Profile" asp-action="Index">Моят профил</a>
                    }

                </div>

                <!-- CONTACT -->
                <div class="footer-col">
                    <h4>Контакти</h4>

                    <div class="footer-contact">
                        <i class="bi bi-envelope"></i>
                        support@foodloop.com
                    </div>

                    <div class="footer-contact">
                        <i class="bi bi-telephone"></i>
                        +359 88 000 0000
                    </div>

                    <div class="footer-contact">
                        <i class="bi bi-geo-alt"></i>
                        Пловдив, България
                    </div>
                </div>

            </div>

            <div class="footer-bottom">

                <span>© 2026 FoodLoop. Всички права запазени.</span>

            </div>

        </footer>
    }


</body>
</html>