@model FoodLoop.ViewModels.Admin.AdminFormViewModel
@using FoodLoop.Helpers

<div class="admin-card">

    <form asp-controller="@AdminControllerHelper.Get(Model.Type)"
          asp-action="@(Model.Id == null ? "Create" : "Edit")"
          method="post"
          enctype="multipart/form-data"
          class="admin-form">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Type" />

        @if (Model.Type == "Restaurant")
        {

            <h3 class="admin-section-title">Бизнес информация</h3>

            <div class="admin-form-grid">

                <div class="admin-field">
                    <label>Име на ресторант</label>
                    <input asp-for="RestaurantName" class="admin-input" required />
                    <span asp-validation-for="RestaurantName" class="text-danger"></span>
                </div>

                <div class="admin-field">
                    <label>Бизнес имейл</label>
                    <input asp-for="BusinessEmail" class="admin-input" required />
                    <span asp-validation-for="BusinessEmail" class="text-danger"></span>
                </div>

                <div class="admin-field">
                    <label>Бизнес телефон</label>
                    <input asp-for="Phone"
                           class="admin-input"
                           maxlength="10"
                           pattern="[0-9]{10}"
                           inputmode="numeric"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                           required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="admin-field">
                    <label>Адрес</label>
                    <input asp-for="Address" class="admin-input" required />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

            </div>

            <h3 class="admin-section-title">Данни за вход</h3>

            <div class="admin-form-grid">

                <div class="admin-field">
                    <label>Име на собственика</label>
                    <input asp-for="OwnerFullName" class="admin-input" required />
                    <span asp-validation-for="OwnerFullName" class="text-danger"></span>
                </div>

                <div class="admin-field">
                    <label>Имейл за вход</label>
                    <input asp-for="OwnerEmail" class="admin-input" required />
                    <span asp-validation-for="OwnerEmail" class="text-danger"></span>
                </div>

                <div class="admin-field">
                    <label>Телефон</label>
                    <input asp-for="OwnerPhone"
                           class="admin-input"
                           maxlength="10"
                           pattern="[0-9]{10}"
                           inputmode="numeric"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                           required />
                    <span asp-validation-for="OwnerPhone" class="text-danger"></span>
                </div>

                @if (Model.Id == null)
                {
                    <div class="admin-field">
                        <label>Парола</label>
                        <input asp-for="OwnerPassword" type="password" class="admin-input" required />
                        <span asp-validation-for="OwnerPassword" class="text-danger"></span>
                    </div>
                }

            </div>

            <h3 class="admin-section-title">Изображения</h3>

            <div class="admin-image-grid">

                <div class="admin-upload">

                    <div class="drop-zone @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "" : "preview")"
                         style="background-image:url('@Model.ImageUrl')">

                        <span>Плъзни изображение</span>

                        <input type="file"
                               name="ImageUpload"
                               accept="image/*">

                    </div>

                    <div class="admin-field">

                        <label>Или URL</label>

                        <input asp-for="ImageUrl"
                               class="admin-input admin-url-input"
                               placeholder="https://example.com/icon.png" />

                    </div>

                </div>

                <div class="admin-upload">

                    <div class="drop-zone @(string.IsNullOrWhiteSpace(Model.BannerImageUrl) ? "" : "preview")"
                         style="background-image:url('@Model.BannerImageUrl')">

                        <span>Плъзни банер</span>

                        <input type="file"
                               name="BannerUpload"
                               accept="image/*">

                    </div>

                    <div class="admin-field">

                        <label>Или URL</label>

                        <input asp-for="BannerImageUrl"
                               class="admin-input admin-url-input"
                               placeholder="https://example.com/banner.png" />

                    </div>

                </div>

            </div>
        }

        <button type="submit" class="admin-btn admin-btn-primary">
            Запази
        </button>

    </form>

</div>