@using FoodLoop.Models.Enums
@using FoodLoop.Models.Entities
@using FoodLoop.Helpers

@model List<FoodLoop.Models.Entities.Reservation>

@{
    ViewData["Title"] = "FoodLoop - Управление на поръчки";
    ViewData["BodyClass"] = "profile-body";

    var pending = Model
        .Where(r => r.Status == ReservationStatus.Pending)
        .ToList();

    var confirmed = Model
        .Where(r => r.Status == ReservationStatus.Confirmed ||
                    r.Status == ReservationStatus.OutForDelivery)
        .ToList();

    var history = Model
        .Where(r => r.Status == ReservationStatus.Finished ||
                    r.Status == ReservationStatus.Canceled)
        .ToList();
}

@functions {

    private string StatusClass(ReservationStatus status)
    {
        return status switch
        {
            ReservationStatus.Pending => "pending",
            ReservationStatus.Confirmed => "confirmed",
            ReservationStatus.OutForDelivery => "outfordelivery",
            ReservationStatus.Finished => "finished",
            ReservationStatus.Canceled => "canceled",
            _ => ""
        };
    }

    private bool HasReachedStatus(Reservation order, ReservationStatus status)
    {
        if (status == ReservationStatus.Pending)
            return true;

        return order.StatusLogs.Any(l => l.NewStatus == status)
               || order.Status == status;
    }
}

<link rel="stylesheet" href="~/css/order-manager.css" />
<link rel="stylesheet" href="~/css/timeline.css" />

<div class="order-app">

    <div class="order-app-header">
        <div>
            <h2 class="dashboard-title">Управление на поръчки</h2>
            <p class="subtitle">Управлявай идващи и активни поръчки</p>
        </div>

        <div class="order-stats">
            <div class="stat-box">
                <span class="stat-number">@pending.Count</span>
                <span class="stat-label">Изчакващи</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@confirmed.Count</span>
                <span class="stat-label">Активни</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@history.Count</span>
                <span class="stat-label">История</span>
            </div>
        </div>
    </div>

    @if (ViewBag.LowStockCount != null && (int)ViewBag.LowStockCount > 0)
    {
        <div class="low-stock-alert">
            Вие имате @ViewBag.LowStockCount оферти/а с ниско количество.
        </div>
    }

    <!-- ================= ИЗЧАКВАЩИ ================= -->

    <h4 class="dashboard-title mb-3">Изчакващи поръчки</h4>

    @if (!pending.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h5>Няма изчакващи поръчки</h5>
            <p>Когато клиент направи нова поръчка, тя ще се появи тук.</p>
        </div>
    }
    else
    {
        @foreach (var order in pending)
        {
            @await Html.PartialAsync("_OrderCard", order)
        }
    }

    <!-- ================= АКТИВНИ ================= -->

    <h4 class="dashboard-title mt-5 mb-3">Активни поръчки</h4>

    @if (!confirmed.Any())
    {
        <div class="empty-state">
            <i class="bi bi-truck"></i>
            <h5>Няма активни поръчки</h5>
            <p>Потвърдените поръчки ще се показват в тази секция.</p>
        </div>
    }
    else
    {
        @foreach (var order in confirmed)
        {
            @await Html.PartialAsync("_OrderCard", order)
        }
    }

    <!-- ================= ИСТОРИЯ ================= -->

    <h4 class="dashboard-title mt-5 mb-3">История на поръчките</h4>

    @if (!history.Any())
    {
        <div class="empty-state">
            <i class="bi bi-clock-history"></i>
            <h5>Няма история на поръчките</h5>
            <p>Завършените или отменени поръчки ще се показват тук.</p>
        </div>
    }
    else
    {
        @foreach (var order in history)
        {
            var index = history.IndexOf(order);
            var hiddenClass = index >= 5 ? "history-hidden" : "";

            <div class="@hiddenClass">
                @await Html.PartialAsync("_OrderCard", order)
            </div>
        }

        @if (history.Count > 5)
        {
            <button id="showMoreBtn" class="btn btn-outline-secondary mt-3">
                Покажи още
            </button>
        }
    }

</div>

@section Scripts {
    <script>
        document.getElementById("showMoreBtn")?.addEventListener("click", function () {
            document.querySelectorAll(".history-hidden").forEach(card => {
                card.style.display = "block";
            });
            this.style.display = "none";
        });

        // 30 min expiration timer

                document.addEventListener("DOMContentLoaded", function () {

            const timers = document.querySelectorAll(".pending-countdown");

            timers.forEach(timer => {

                const expiresAt = new Date(timer.dataset.expires);

                function updateTimer() {

                    const now = new Date();
                    const diff = Math.floor((expiresAt - now) / 1000);

                    if (diff <= 0) {
                        timer.textContent = "00:00";
                        timer.classList.add("warning");
                        return;
                    }

                    const minutes = Math.floor(diff / 60);
                    const seconds = diff % 60;

                    timer.textContent =
                        String(minutes).padStart(2, '0') + ":" +
                        String(seconds).padStart(2, '0');

                    if (diff <= 300) {
                        timer.classList.add("warning");
                    }
                }

                updateTimer();
                setInterval(updateTimer, 1000);
            });

        });
    </script>
}