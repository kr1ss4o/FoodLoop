@using FoodLoop.Models.Enums
@model List<FoodLoop.Models.Entities.Reservation>

@{

    ViewData["Title"] = "Order Manager";
    ViewData["BodyClass"] = "profile-body";

    var pending = Model.Where(r => r.Status == ReservationStatus.Pending).ToList();

    var confirmed = Model.Where(r =>

    r.Status == ReservationStatus.Confirmed ||

    r.Status == ReservationStatus.OutForDelivery);

    var history = Model
        .Where(r => r.Status == ReservationStatus.Finished || r.Status == ReservationStatus.Canceled)
        .ToList();

    string FormatStatus(ReservationStatus status)
        => System.Text.RegularExpressions.Regex.Replace(status.ToString(), "([a-z])([A-Z])", "$1 $2");

    string StatusClass(ReservationStatus status)
        => status switch
        {
            ReservationStatus.Pending => "pending",
            ReservationStatus.Confirmed => "confirmed",
            ReservationStatus.OutForDelivery => "outfordelivery",
            ReservationStatus.Finished => "finished",
            ReservationStatus.Canceled => "canceled",
            _ => ""
        };
}

<link rel="stylesheet" href="~/css/order-manager.css" />

<div class="order-manager-wrapper">

    <h2 class="dashboard-title">Order Manager</h2>

    <!-- ================= PENDING ================= -->

    <h4 class="section-heading">Pending Orders</h4>

    @if (!pending.Any())
    {
        <p class="empty-text">No pending orders.</p>
    }
    else
    {
        @foreach (var order in pending)
        {
            <div class="dashboard-card pending-card">

                <div class="card-header-row">
                    <div>
                        <strong>Order #@order.Id.ToString().Substring(0, 6)</strong>
                        <div class="small-text">
                            @if (order.IsForSomeoneElse)
                            {
                                <div class="small-text">
                                    <strong>Recipient:</strong> @order.RecipientFullName · @order.RecipientPhone
                                </div>
                                <div class="small-text text-muted">
                                    Ordered by: @order.User.FullName
                                </div>
                            }
                            else
                            {
                                <div class="small-text">
                                    @order.User.FullName · @order.User.PhoneNumber
                                </div>
                            }
                        </div>
                        <div class="small-text">
                            Delivery: @order.DeliveryType
                        </div>
                    </div>

                    <span class="status-badge @StatusClass(order.Status)">
                        @FormatStatus(order.Status)
                    </span>
                </div>

                <div class="items-section">
                    @foreach (var item in order.Items)
                    {
                        <div class="item-line">
                            @item.Offer.Title (Quantity: @item.Quantity)
                        </div>
                    }
                </div>

                <div class="card-footer-row">
                    <div class="order-total">
                        Total: @order.TotalPrice EUR
                    </div>

                    <div class="actions">
                        <form asp-action="Confirm" method="post">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button class="btn-action confirm-btn">Confirm</button>
                        </form>

                        <form asp-action="Cancel" method="post">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button class="btn-action cancel-btn">Cancel</button>
                        </form>
                    </div>
                </div>

            </div>
        }
    }

    <!-- ================= CONFIRMED ================= -->

    <h4 class="section-heading mt-5">Confirmed Orders</h4>

    @if (!confirmed.Any())
    {
        <p class="empty-text">No confirmed orders.</p>
    }
    else
    {
        @foreach (var order in confirmed)
        {
            <div class="dashboard-card confirmed-card">

                <div class="card-header-row">
                    <div>
                        <strong>Order #@order.Id.ToString().Substring(0, 6)</strong>
                        <div class="small-text">
                            @if (order.IsForSomeoneElse)
                            {
                                <div class="small-text">
                                    <strong>Recipient:</strong> @order.RecipientFullName · @order.RecipientPhone
                                </div>
                                <div class="small-text text-muted">
                                    Ordered by: @order.User.FullName
                                </div>
                            }
                            else
                            {
                                <div class="small-text">
                                    @order.User.FullName · @order.User.PhoneNumber
                                </div>
                            }

                        </div>
                        <div class="small-text">
                            Delivery: @order.DeliveryType
                        </div>
                    </div>

                    <span class="status-badge @StatusClass(order.Status)">
                        @FormatStatus(order.Status)
                    </span>
                </div>

                <div class="items-section">
                    @foreach (var item in order.Items)
                    {
                        <div class="item-line">
                            @item.Offer.Title (Quantity: @item.Quantity)
                        </div>
                    }
                </div>

                <div class="card-footer-row">
                    <div class="order-total">
                        Total: @order.TotalPrice EUR
                    </div>

                    <div class="actions">

                        @if (order.DeliveryType == "Delivery" && order.Status == ReservationStatus.Confirmed)
                        {
                            <form asp-action="OutForDelivery" method="post">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button class="btn-action delivery-btn">
                                    Out for delivery
                                </button>
                            </form>
                        }

                        <form asp-action="Finish" method="post">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button class="btn-action finish-btn">
                                Finish
                            </button>
                        </form>

                        <form asp-action="Cancel" method="post">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button class="btn-action cancel-btn">
                                Cancel
                            </button>
                        </form>
                    </div>

                </div>

            </div>
        }
    }

    <!-- ================= HISTORY ================= -->

    <h4 class="section-heading mt-5">Order History</h4>

    @if (!history.Any())
    {
        <p class="empty-text">No past orders.</p>
    }
    else
    {
        @foreach (var order in history)
        {
            <div class="dashboard-card history-card">

                <div class="card-header-row">
                    <div>
                        <strong>Order #@order.Id.ToString().Substring(0, 6)</strong>

                        @if (order.IsForSomeoneElse)
                        {
                            <div class="small-text">
                                Recipient: @order.RecipientFullName · @order.RecipientPhone
                            </div>
                            <div class="small-text text-muted">
                                Ordered by: @order.User.FullName
                            </div>
                        }
                        else
                        {
                            <div class="small-text">
                                @order.User.FullName · @order.User.PhoneNumber
                            </div>
                        }

                        <div class="small-text">
                            Delivery: @order.DeliveryType
                        </div>
                    </div>


                    <span class="status-badge @StatusClass(order.Status)">
                        @FormatStatus(order.Status)
                    </span>
                </div>

                <div class="items-section">
                    @foreach (var item in order.Items)
                    {
                        <div class="item-line">
                            @item.Offer.Title (Quantity: @item.Quantity)
                        </div>
                    }
                </div>

                <div class="card-footer-row">
                    <div class="order-total">
                        Total: @order.TotalPrice EUR
                    </div>
                </div>

            </div>
        }
    }

</div>