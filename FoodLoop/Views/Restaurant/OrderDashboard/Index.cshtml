@using FoodLoop.Models.Enums
@model List<FoodLoop.Models.Entities.Reservation>

@{
    ViewData["Title"] = "Order Dashboard";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/order-dashboard.css" />

<h2 class="section-title">Pending orders:</h2>

@{
    var pending = Model.Where(r => r.Status == ReservationStatus.Pending).ToList();
}

@if (!pending.Any())
{
    <p class="empty-text">No pending orders.</p>
}
else
{
    foreach (var p in pending)
    {
        <div class="order-card">
            <div class="order-info">
                <p class="title">@p.Offer.Title</p>
                <p><strong>Client name:</strong> @p.User.FullName</p>
                <p><strong>Client phone:</strong> @p.User.PhoneNumber</p>
            </div>

            <div class="status-box">
                <form method="post" action="/BusinessProfile/Cancel">
                    <input type="hidden" name="id" value="@p.Id" />
                    <button class="cancel-btn">Cancel</button>
                </form>

                <form method="post" action="/BusinessProfile/Confirm">
                    <input type="hidden" name="id" value="@p.Id" />
                    <button class="confirm-btn">Confirm</button>
                </form>
            </div>

            <img src="@p.Offer.ImageUrl" class="order-image" />
        </div>
    }
}



<h2 class="section-title" style="margin-top:40px;">Confirmed orders:</h2>

@{
    var confirmed = Model
        .Where(r => r.Status == ReservationStatus.Confirmed)
        .OrderByDescending(r => r.CreatedAt)
        .ToList();

    var confirmedPreview = confirmed.Take(3).ToList();
    var confirmedMore = confirmed.Skip(3).ToList();
}

@if (!confirmed.Any())
{
    <p class="empty-text">No confirmed orders.</p>
}
else
{
    <div id="confirmed-container">

        <!-- ALWAYS SHOW FIRST 3 -->
        @foreach (var c in confirmedPreview)
        {
            <div class="order-card">
                <div class="order-info">
                    <p class="title">@c.Offer.Title</p>
                    <p><strong>Client name:</strong> @c.User.FullName</p>
                    <p><strong>Client phone:</strong> @c.User.PhoneNumber</p>
                </div>

                <div class="status-box">
                    <form method="post" action="/BusinessProfile/Cancel">
                        <input type="hidden" name="id" value="@c.Id" />
                        <button class="cancel-btn">Cancel</button>
                    </form>

                    <form method="post" action="/BusinessProfile/Finish">
                        <input type="hidden" name="id" value="@c.Id" />
                        <button class="finish-btn">Finish</button>
                    </form>
                </div>

                <img src="@c.Offer.ImageUrl" class="order-image" />
            </div>
        }

        <!-- MORE (HIDDEN INITIALLY) -->
        <div id="confirmed-more" style="display:none;">
            @foreach (var c in confirmedMore)
            {
                <div class="order-card">
                    <div class="order-info">
                        <p class="title">@c.Offer.Title</p>
                        <p><strong>Client name:</strong> @c.User.FullName</p>
                        <p><strong>Client phone:</strong> @c.User.PhoneNumber</p>
                    </div>

                    <div class="status-box">
                        <form method="post" action="/BusinessProfile/Cancel">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button class="cancel-btn">Cancel</button>
                        </form>

                        <form method="post" action="/BusinessProfile/Finish">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button class="finish-btn">Finish</button>
                        </form>
                    </div>

                    <img src="@c.Offer.ImageUrl" class="order-image" />
                </div>
            }
        </div>

        @if (confirmed.Count > 3)
        {
            <button id="btn-confirmed-toggle" class="show-more-btn">Show more</button>
        }
    </div>
}

<h2 class="section-title" style="margin-top:40px;">Order history:</h2>

@{
    var history = Model
        .Where(r => r.Status == ReservationStatus.Finished || r.Status == ReservationStatus.Canceled)
        .OrderByDescending(r => r.CreatedAt)
        .ToList();

    var historyPreview = history.Take(3).ToList();
    var historyMore = history.Skip(3).ToList();
}

@if (!history.Any())
{
    <p class="empty-text">No past orders.</p>
}
else
{
    <div id="history-container">

        @foreach (var h in historyPreview)
        {
            <div class="order-card history">
                <div class="order-info">
                    <p class="title">@h.Offer.Title</p>
                    <p><strong>Client name:</strong> @h.User.FullName</p>
                    <p><strong>Client phone:</strong> @h.User.PhoneNumber</p>
                    <p>
                        <strong>Status:</strong>
                        <span class="history-status @(h.Status == ReservationStatus.Finished ? "finished" : "canceled")">
                            @h.Status
                        </span>
                    </p>
                </div>

                <img src="@h.Offer.ImageUrl" class="order-image" />
            </div>
        }

        <div id="history-more" style="display:none;">
            @foreach (var h in historyMore)
            {
                <div class="order-card history">
                    <div class="order-info">
                        <p class="title">@h.Offer.Title</p>
                        <p><strong>Client name:</strong> @h.User.FullName</p>
                        <p><strong>Client phone:</strong> @h.User.PhoneNumber</p>
                        <p>
                            <strong>Status:</strong>
                            <span class="history-status @(h.Status == ReservationStatus.Finished ? "finished" : "canceled")">
                                @h.Status
                            </span>
                        </p>
                    </div>

                    <img src="@h.Offer.ImageUrl" class="order-image" />
                </div>
            }
        </div>

        @if (history.Count > 3)
        {
            <button id="btn-history-toggle" class="show-more-btn">Show more</button>
        }
    </div>
}

@section Scripts {
    <script src="~/js/order-dashboard.js"></script>

    @if (TempData["Success"] != null)
    {
        <script>showToast("@TempData["Success"]", "success");</script>
    }

    @if (TempData["Error"] != null)
    {
        <script>showToast("@TempData["Error"]", "error");</script>
    }
}