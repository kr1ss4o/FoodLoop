@using FoodLoop.Models.Enums
@using FoodLoop.Models.Entities
@model List<FoodLoop.Models.Entities.Reservation>

@{
    ViewData["Title"] = "Order Manager";
    ViewData["BodyClass"] = "profile-body";

    var pending = Model
        .Where(r => r.Status == ReservationStatus.Pending)
        .ToList();

    var confirmed = Model
        .Where(r => r.Status == ReservationStatus.Confirmed ||
                    r.Status == ReservationStatus.OutForDelivery)
        .ToList();

    var history = Model
        .Where(r => r.Status == ReservationStatus.Finished ||
                    r.Status == ReservationStatus.Canceled)
        .ToList();
}

@functions {
    private string FormatStatus(ReservationStatus status)
    {
        return System.Text.RegularExpressions.Regex
            .Replace(status.ToString(), "([a-z])([A-Z])", "$1 $2");
    }

    private string StatusClass(ReservationStatus status)
    {
        return status switch
        {
            ReservationStatus.Pending => "pending",
            ReservationStatus.Confirmed => "confirmed",
            ReservationStatus.OutForDelivery => "outfordelivery",
            ReservationStatus.Finished => "finished",
            ReservationStatus.Canceled => "canceled",
            _ => ""
        };
    }

    private bool HasReachedStatus(Reservation order, ReservationStatus status)
    {
        if (status == ReservationStatus.Pending)
            return true;

        return order.StatusLogs.Any(l => l.NewStatus == status)
               || order.Status == status;
    }
}

<link rel="stylesheet" href="~/css/order-manager.css" />
<link rel="stylesheet" href="~/css/timeline.css" />

<div class="order-app">

    <!-- HEADER -->
    <div class="order-app-header">
        <div>
            <h2 class="dashboard-title">Управление на поръчки</h2>
            <p class="subtitle">Управлявай идващи и активни поръчки</p>
        </div>

        <div class="order-stats">
            <div class="stat-box">
                <span class="stat-number">@pending.Count</span>
                <span class="stat-label">Изчакващи</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@confirmed.Count</span>
                <span class="stat-label">Активни</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@history.Count</span>
                <span class="stat-label">История</span>
            </div>
        </div>
    </div>

    @if (ViewBag.LowStockCount != null && (int)ViewBag.LowStockCount > 0)
    {
        <div class="low-stock-alert">
            Вие имате @ViewBag.LowStockCount оферти/а с ниско количество.
        </div>
    }

    <!-- ================= PENDING ================= -->

    <h4 class="section-heading">Изчакващи оферти</h4>

    @if (!pending.Any())
    {
        <p class="empty-text">В момента нямате изчакващи оферти</p>
    }
    else
    {
        @foreach (var order in pending)
        {
            <div class="order-card">

                <!-- HEADER -->
                <div class="order-card-header">

                    <div class="order-left">

                        <div class="order-id">
                            Order #@order.Id.ToString().Substring(0, 6)
                        </div>

                        <div class="order-date">
                            @order.CreatedAt.ToLocalTime().ToString("dd MMM yyyy • HH:mm")
                        </div>

                        @if (order.IsForSomeoneElse)
                        {
                            <div class="order-meta-line">
                                <strong>Получател:</strong>
                                @order.RecipientFullName · @order.RecipientPhone
                            </div>

                            <div class="order-meta-line muted">
                                Поръчана от: @order.User.FullName
                            </div>
                        }
                        else
                        {
                            <div class="order-meta-line">
                                @order.User.FullName · @order.User.PhoneNumber
                            </div>
                        }

                        <div class="order-meta-line">
                            <strong>Вид доставка:</strong> @order.DeliveryType
                        </div>

                        @if (order.DeliveryType == "Delivery" &&
                                        !string.IsNullOrEmpty(order.DeliveryAddress))
                        {
                            <div class="order-meta-line">
                                <strong>Адрес:</strong> @order.DeliveryAddress
                            </div>
                        }

                    </div>

                    <div class="order-right">
                        <span class="status-badge @StatusClass(order.Status)">
                            @FormatStatus(order.Status)
                        </span>
                    </div>

                </div>

                <!-- ITEMS -->
                <div class="order-items">
                    @foreach (var item in order.Items)
                    {
                        <div class="order-item">
                            <span>@item.Offer.Title</span>
                            <span class="qty">Количество: @item.Quantity бр.</span>
                        </div>
                    }
                </div>

                <!-- TIMELINE -->
                <div class="client-timeline modern">

                    @{
                        var steps = new List<ReservationStatus>
                        {
                        ReservationStatus.Pending,
                        ReservationStatus.Confirmed,
                        ReservationStatus.OutForDelivery,
                        ReservationStatus.Finished
                        };

                        if (order.Status == ReservationStatus.Canceled)
                        {
                            steps.Add(ReservationStatus.Canceled);
                        }
                    }

                    @foreach (var step in steps)
                    {
                        if (step == ReservationStatus.OutForDelivery &&
                        order.DeliveryType != "Delivery")
                        {
                            continue;
                        }

                        var reached = HasReachedStatus(order, step);

                        var time = order.StatusLogs
                        .Where(l => l.NewStatus == step)
                        .OrderBy(l => l.ChangedAt)
                        .Select(l => (DateTime?)l.ChangedAt)
                        .FirstOrDefault();

                        <div class="timeline-step @(reached ? "done" : "")
                                                    @(step == ReservationStatus.Canceled ? "cancel" : "")">

                            <div class="circle"></div>

                            <span>@step</span>

                            @if (time != null)
                            {
                                <small class="timeline-time">
                                    @time.Value.ToLocalTime().ToString("HH:mm")
                                </small>
                            }
                        </div>

                        if (step != steps.Last())
                        {
                            <div class="timeline-line"></div>
                        }
                    }

                </div>

                <!-- FOOTER -->
                <div class="order-card-footer">

                    <div class="order-total">
                        Обща сума: @order.TotalPrice EUR
                    </div>

                    <div class="actions">
                        <!-- бутоните ти остават същите -->
                    </div>

                </div>

            </div>
        }
    }

