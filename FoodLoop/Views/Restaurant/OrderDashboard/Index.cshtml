                        }

                        <div class="order-meta-line">
                            <strong>Вид доставка:</strong> @order.DeliveryType
                        </div>

                        @if (order.DeliveryType == "Delivery" &&
                                        !string.IsNullOrEmpty(order.DeliveryAddress))
                        {
                            <div class="order-meta-line">
                                <strong>Адрес:</strong> @order.DeliveryAddress
                            </div>
                        }

                    </div>

                    <div class="order-right">
                        <span class="status-badge @StatusClass(order.Status)">
                            @FormatStatus(order.Status)
                        </span>
                    </div>

                </div>

                <!-- ITEMS -->
                <div class="order-items">
                    @foreach (var item in order.Items)
                    {
                        <div class="order-item">
                            <span>@item.Offer.Title</span>
                            <span class="qty">Количество: @item.Quantity бр.</span>
                        </div>
                    }
                </div>

                <!-- TIMELINE -->
                <div class="client-timeline modern">

                    @{
                        var steps = new List<ReservationStatus>
                        {
                        ReservationStatus.Pending,
                        ReservationStatus.Confirmed,
                        ReservationStatus.OutForDelivery,
                        ReservationStatus.Finished
                        };

                        if (order.Status == ReservationStatus.Canceled)
                        {
                            steps.Add(ReservationStatus.Canceled);
                        }
                    }

                    @foreach (var step in steps)
                    {
                        if (step == ReservationStatus.OutForDelivery &&
                        order.DeliveryType != "Delivery")
                        {
                            continue;
                        }

                        var reached = HasReachedStatus(order, step);

                        var time = order.StatusLogs
                        .Where(l => l.NewStatus == step)
                        .OrderBy(l => l.ChangedAt)
                        .Select(l => (DateTime?)l.ChangedAt)
                        .FirstOrDefault();

                        <div class="timeline-step @(reached ? "done" : "")
                                                    @(step == ReservationStatus.Canceled ? "cancel" : "")">

                            <div class="circle"></div>

                            <span>@step</span>

                            @if (time != null)
                            {
                                <small class="timeline-time">
                                    @time.Value.ToLocalTime().ToString("HH:mm")
                                </small>
                            }
                        </div>

                        if (step != steps.Last())
                        {
                            <div class="timeline-line"></div>
                        }
                    }

                </div>

                <!-- FOOTER -->
                <div class="order-card-footer">

                    <div class="order-total">
                        Обща сума: @order.TotalPrice EUR
                    </div>

                    <div class="actions">
                        <!-- бутоните ти остават същите -->
                    </div>

                </div>

            </div>
        }

        @if (history.Count > 5)
        {
            <button id="showMoreBtn" class="btn btn-outline-secondary mt-3">
                Покажи още
            </button>
        }
    }

</div>

@section Scripts {
    <script>
        document.getElementById("showMoreBtn")?.addEventListener("click", function () {
            document.querySelectorAll(".history-hidden").forEach(card => {
                card.style.display = "block";
            });
            this.style.display = "none";
        });
    </script>
}