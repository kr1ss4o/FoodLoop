@model FoodLoop.Models.ViewModels.RestaurantDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<link rel="stylesheet" href="~/css/restaurant-details.css" />

<div class="restaurant-hero">
    <img class="hero-banner"
         src="@(string.IsNullOrEmpty(Model.BannerImageUrl)
                                  ? "/images/default-banner.jpg" 
                                  : Model.BannerImageUrl)" />

    <a href="#reviews" class="hero-rating">
        <i class="bi bi-star-fill"></i>
        @Model.AvgRating
        <span>(@Model.ReviewsCount отзива)</span>
    </a>
</div>

<div class="restaurant-card">

    <div class="restaurant-header">

        <div class="restaurant-left">

            <div class="restaurant-logo">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                                                      ? "/images/default-restaurant.png"
                                                                      : Model.ImageUrl)" />
            </div>

            <div class="restaurant-main">

                <h1>@Model.Name</h1>

                <div class="restaurant-address">
                    📍 @Model.Address
                </div>

                <div class="restaurant-tags">
                    <span class="tag cuisine">Ресторант</span>
                    <span class="tag open">Отворено в момента</span>
                </div>

            </div>

        </div>


        <div class="restaurant-actions">

            <a class="btn dark">
                ✉ Изпрати имейл
            </a>

            <a class="btn outline">
                📞 Обади се
            </a>

        </div>

    </div>

    <div class="restaurant-info">

        <div class="info-item">
            <div class="icon">✉</div>
            <div>
                <label>ИМЕЙЛ НА РЕСТОРАНТА</label>
                <p>contact@restaurant.com</p>
            </div>
        </div>

        <div class="info-item">
            <div class="icon">📞</div>
            <div>
                <label>ТЕЛЕФОН</label>
                <p>+359 888 123 456</p>
            </div>
        </div>

        <div class="info-item">
            <div class="icon">🚚</div>
            <div>
                <label>ЦЕНА НА ДОСТАВКА:</label>
                <p>2.00 €</p>
            </div>
        </div>

    </div>

</div>

<div class="restaurant-stats">

    <div class="stat stat-yellow">
        <i class="bi bi-chat-left-text stat-icon"></i>
        <div class="stat-number">@Model.ReviewsCount</div>
        <div class="stat-label">Общо отзиви</div>
    </div>

    <div class="stat stat-green">
        <i class="bi bi-star stat-icon"></i>
        <div class="stat-number">@Model.AvgRating</div>
        <div class="stat-label">Средна оценка</div>
    </div>

    <div class="stat stat-pink">
        <i class="bi bi-ticket-perforated stat-icon"></i>
        <div class="stat-number">@Model.ActiveOffers.Count</div>
        <div class="stat-label">Активни оферти</div>
    </div>

    <div class="stat stat-blue">
        <i class="bi bi-box-seam stat-icon"></i>
        <div class="stat-number">0</div>
        <div class="stat-label">Изпълнени поръчки</div>
    </div>

</div>

@if (Model.ActiveOffers != null && Model.ActiveOffers.Any())
{
    <div class="offers-section">

        <div class="section-header">
            <h2 class="section-title">
                Налични оферти
            </h2>

            <span class="section-subtitle">
                Прясна храна, спасена от изхвърляне
            </span>
        </div>

        <div class="offers-grid">

            @foreach (var offer in Model.ActiveOffers)
            {
                var discount = (int)Math.Round(
                (1 - (offer.DiscountedPrice / offer.OriginalPrice)) * 100
                );

                <a asp-controller="Offers"
                       asp-action="Details"
                       asp-route-id="@offer.Id"
                       class="offer-card card-link">

                    <div class="offer-image">

                        <img src="@offer.ImageUrl" />

                        <span class="discount-badge">
                            -@discount%
                        </span>

                    </div>

                    <div class="offer-content">

                        <h3 class="offer-title">
                            @offer.Title
                        </h3>

                        <div class="offer-prices">

                            <span class="price-old">
                                @offer.OriginalPrice €
                            </span>

                            <span class="price-new">
                                @offer.DiscountedPrice €
                            </span>

                        </div>

                        <div class="offer-meta">

                            <span class="offer-stock">
                                <i class="bi bi-box"></i>
                                Остават @offer.QuantityAvailable
                            </span>

                            <span class="offer-countdown"
                                  data-end="@offer.EndsAt.ToString("o")">
                                <i class="bi bi-hourglass-split"></i>
                            </span>

                        </div>

                    </div>

                </a>
            }

        </div>

    </div>
}


@if (Model.LatestReviews.Any())
{
    <div id="reviews" class="reviews-section">

        <div class="reviews-header">

            <div class="reviews-title-group">

                <h2 class="reviews-title">
                    Какво казват клиентите
                </h2>

                <div class="reviews-rating">

                    <i class="bi bi-star-fill"></i>
                    <span>@Model.AvgRating</span>

                    <span class="reviews-count">
                        (@Model.ReviewsCount отзива)
                    </span>

                </div>

            </div>

        </div>

        <div class="reviews-list">

            @for (int i = 0; i < Model.LatestReviews.Count; i++)
            {
                var review = Model.LatestReviews[i];

                <div class="review-card rating-@review.Rating review-item @(i >= 5 ? "hidden-review" : "")">

                    <div class="review-top">

                        <div class="review-stars">

                            @for (int s = 0; s < review.Rating; s++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }

                            @for (int s = review.Rating; s < 5; s++)
                            {
                                <i class="bi bi-star"></i>
                            }

                        </div>

                        <span class="review-date">
                            @review.CreatedAt.ToString("dd MMM yyyy")
                        </span>

                    </div>

                    <p class="review-text">
                        "@review.Comment"
                    </p>

                    <div class="review-footer">

                        <div class="review-author">
                            <i class="bi bi-person-circle"></i>
                            @review.AuthorName
                        </div>

                    </div>

                </div>
            }

            @if (Model.LatestReviews.Count > 5)
            {
                <div class="reviews-show-more">

                    <button id="showMoreReviews" class="show-more-btn">
                        Покажи още отзиви
                        <i class="bi bi-chevron-down"></i>
                    </button>

                </div>
            }

        </div>

    </div>
}


<script>
    function updateOfferTimers(){

        const timers = document.querySelectorAll(".offer-countdown");

        timers.forEach(timer => {

            const end = new Date(timer.dataset.end);
            const now = new Date();

            const diff = end - now;

            if(diff <= 0){

                timer.className = "offer-countdown expired";
                timer.innerHTML = '<i class="bi bi-hourglass"></i> Изтекла';

                return;
            }

            const hours = Math.floor(diff / 1000 / 60 / 60);
            const minutes = Math.floor((diff / 1000 / 60) % 60);

            let text = `${hours}ч ${minutes}м`;

            timer.classList.remove("urgent","warning","safe");

            if(hours < 1){
                timer.classList.add("urgent");
            }
            else if(hours < 3){
                timer.classList.add("warning");
            }
            else{
                timer.classList.add("safe");
            }

            timer.innerHTML =
            `<i class="bi bi-hourglass-split"></i> ${text}`;

        });

    }

    updateOfferTimers();
    setInterval(updateOfferTimers,60000);
</script>