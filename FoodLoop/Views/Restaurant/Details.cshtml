@model FoodLoop.Models.ViewModels.RestaurantDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<link rel="stylesheet" href="~/css/restaurant-details.css" />

<div class="rdt-wrapper">

    <!-- HERO -->
    <section class="rdt-hero">
        <div class="rdt-hero-left">
            <h1 class="rdt-title">@Model.Name</h1>

            <div class="rdt-meta">
                <div class="rdt-rating">
                    <span class="rdt-rating-badge">
                        ⭐ @(Model.ReviewsCount == 0 ? "—" : $"{Model.AvgRating:0.0}/5")
                    </span>
                    <span class="rdt-rating-count">
                        (@Model.ReviewsCount reviews)
                    </span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Address))
                {
                    <div class="rdt-address">📍 @Model.Address</div>
                }
            </div>

            <div class="rdt-actions">
                <a asp-controller="Offers" asp-action="Index" class="rdt-btn rdt-btn-outline">
                    ← Back to offers
                </a>
                <a asp-controller="Restaurant" asp-action="Index" class="rdt-btn rdt-btn-primary">
                    View all restaurants
                </a>
            </div>
        </div>

        <div class="rdt-hero-right">
            <img class="rdt-image"
                 src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)"
                 alt="@Model.Name" />
        </div>
    </section>

    <!-- OFFERS -->
    <section class="rdt-section">
        <div class="rdt-section-header">
            <h2>Active offers</h2>
            <span class="rdt-muted">@Model.ActiveOffers.Count offer(s)</span>
        </div>

        @if (!Model.ActiveOffers.Any())
        {
            <div class="rdt-empty">
                No active offers available right now.
            </div>
        }
        else
        {
            <div class="rdt-offers-grid">
                @foreach (var offer in Model.ActiveOffers)
                {
                    <a asp-controller="Offers"
                       asp-action="Details"
                       asp-route-id="@offer.Id"
                       class="rdt-offer-link">

                        <article class="rdt-offer-card">
                            <img class="rdt-offer-img"
                                 src="@(string.IsNullOrEmpty(offer.ImageUrl) ? "/images/no-image.png" : offer.ImageUrl)"
                                 alt="@offer.Title" />

                            <div class="rdt-offer-body">
                                <div class="rdt-offer-title">@offer.Title</div>
                                <div class="rdt-offer-price">@offer.DiscountedPrice.ToString("F2") EUR</div>

                                <div class="rdt-offer-stock">
                                    @if (offer.QuantityAvailable <= 3)
                                    {
                                        <span class="rdt-stock-badge urgent">🔥 Almost gone: @offer.QuantityAvailable</span>
                                    }
                                    else if (offer.QuantityAvailable <= 5)
                                    {
                                        <span class="rdt-stock-badge low">Only @offer.QuantityAvailable left</span>
                                    }
                                    else
                                    {
                                        <span class="rdt-muted">@offer.QuantityAvailable available</span>
                                    }
                                </div>
                            </div>
                        </article>

                    </a>
                }
            </div>
        }
    </section>

    <!-- REVIEWS -->
    <section class="rdt-section">
        <div class="rdt-section-header">
            <h2>Latest reviews</h2>
            <span class="rdt-muted">Last 5 reviews</span>
        </div>

        @if (Model.LatestReviews == null || !Model.LatestReviews.Any())
        {
            <div class="rdt-empty">
                No reviews yet.
            </div>
        }
        else
        {
            <div class="rdt-reviews-grid">
                @foreach (var r in Model.LatestReviews)
                {
                    <article class="rdt-review-card">

                        <div class="rdt-review-top">
                            <div class="rdt-review-author">@r.AuthorName</div>
                            <div class="rdt-review-date">@r.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                        </div>

                        <div class="rdt-stars" aria-label="Rating @r.Rating out of 5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="rdt-star @(i <= r.Rating ? "filled" : "")">★</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(r.Comment))
                        {
                            <div class="rdt-review-text">“@r.Comment”</div>
                        }
                        else
                        {
                            <div class="rdt-review-text rdt-muted">No comment.</div>
                        }

                    </article>
                }
            </div>
        }
    </section>

</div>