@model FoodLoop.Models.ViewModels.OfferFormViewModel
@{
    ViewData["Title"] = "Create Offer";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/offers-manage.css" />

<div class="offer-form-wrapper">

    <h2 class="form-title">Create new offer</h2>

    <form asp-action="Create" asp-controller="OfferManager"
          method="post" enctype="multipart/form-data" class="offer-form">

        <label>Title:</label>
        <input asp-for="Offer.Title" class="input" required />

        <label>Description:</label>
        <textarea asp-for="Offer.Description" class="input" required></textarea>

        <label>Original price:</label>
        <input asp-for="Offer.OriginalPrice" class="input" type="number" step="0.01" required />

        <label>Discounted price:</label>
        <input asp-for="Offer.DiscountedPrice" class="input" type="number" step="0.01" required />

        <label>Available quantity:</label>
        <input asp-for="Offer.QuantityAvailable" type="number" class="input" min="1" required />


        <!-- CATEGORY DROPDOWN -->
        <label>Category:</label>
        <select asp-for="Offer.CategoryId" class="input" required>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>


        <!-- TAG SELECTION -->
        <label>Tags:</label>
        <div class="tag-list">
            @foreach (var tag in Model.Tags)
            {
                <label class="tag-checkbox">
                    <input type="checkbox" name="SelectedTags" value="@tag.Id" />
                    @tag.Name
                </label>
            }
        </div>


        <label>Ends at:</label>
        <input asp-for="Offer.EndsAt" type="datetime-local" class="input" required />

        <label>Image:</label>
        <input type="file" name="ImageUpload" accept="image/*" class="input" required />

        <button type="submit" class="submit-btn">Create offer</button>
    </form>

</div>

@section Scripts {
    @if (TempData["Error"] != null)
    {
        <script>showToast("@TempData["Error"]", "error");</script>
    }
    @if (TempData["Success"] != null)
    {
        <script>showToast("@TempData["Success"]", "success");</script>
    }
}