@model List<FoodLoop.Models.Entities.Offer>
@{
    ViewData["Title"] = "FoodLoop - Управление на оферти";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/offers-manage.css" />

<div class="page-header">

    <h2 class="page-title">Мениджър на оферти</h2>

    <a class="create-btn" href="/OfferManager/Create">
        Създай нова оферта
    </a>

</div>

@if (!Model.Any())
{
    <div class="empty-box">

        <div class="empty-icon">
            <i class="bi bi-box-seam"></i>
        </div>

        <h3>Нямате оферти</h3>

        <p>
            Създайте първата си оферта и започнете да продавате.
        </p>

    </div>
}
else
{
    <div class="offer-grid">
        @foreach (var offer in Model)
        {
            <div class="offer-card">
                <img src="@offer.ImageUrl" class="offer-img" />

                <h3 class="offer-title">@offer.Title</h3>

                <div class="pricing">
                    <span class="new-price">@offer.DiscountedPrice EUR</span>
                    <span class="old-price">@offer.OriginalPrice EUR</span>
                </div>

                <p class="small-info">
                    Количество: @offer.QuantityAvailable

                    @if (offer.IsLowStock)
                    {
                        <span class="low-stock-badge">Ниско количество</span>
                    }
                </p>
                <p class="small-info">Край: @offer.EndsAt.ToShortDateString()</p>

                <div class="actions">
                    <a href="/OfferManager/Edit/@offer.Id"
                       class="icon-btn edit-btn"
                       title="Edit">

                        <svg class="action-icon"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round">
                            <path d="M12 20h9" />
                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                        </svg>
                        <span>Редактирай</span>
                    </a>

                    <form method="post"
                          action="/OfferManager/Delete/@offer.Id"
                          onsubmit="return confirm('Delete this offer?');">

                          @Html.AntiForgeryToken()

                        <button type="submit" class="icon-btn delete-btn" title="Delete">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}