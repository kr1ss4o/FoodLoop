@model FoodLoop.ViewModels.Admin.AdminFormViewModel

@{
    Layout = "_Layout";

    var modelName = Model.Type switch
    {
        "Restaurant" => "ресторант",
        "Offer" => "оферта",
        "Category" => "категория",
        "Tag" => "таг",
        _ => Model.Type.ToLower()
    };
}

<div class="admin-header">
    <h2>Създай @modelName</h2>
</div>

<partial name="_AdminForm" model="Model" />