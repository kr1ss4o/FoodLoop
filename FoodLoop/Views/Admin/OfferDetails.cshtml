@model FoodLoop.Models.Entities.Offer
@using FoodLoop.Models.Entities

@{
    ViewData["Title"] = "Offer Details";
    var isExpired = Model.EndsAt <= DateTime.UtcNow;
    var tags = Model.OfferTags ?? Enumerable.Empty<OfferTag>();
}

<div class="admin-wrapper">

    <!-- HEADER -->
    <div class="admin-header">
        <div>
            <h1 class="admin-title">@Model.Title</h1>
            <div class="admin-subtitle">
                Restaurant: @Model.Restaurant?.Name
            </div>
        </div>

        <a asp-action="Offers" class="btn-details">Back</a>
    </div>

    <!-- CARD -->
    <div class="admin-card">

        <div class="details-grid">

            <!-- ID -->
            <div class="details-block">
                <div class="details-label">Offer ID</div>
                <div class="details-value">@Model.Id</div>
            </div>

            <!-- CATEGORY -->
            <div class="details-block">
                <div class="details-label">Category</div>
                <div class="details-value">
                    @(Model.Category?.Name ?? "—")
                </div>
            </div>

            <!-- ORIGINAL PRICE -->
            <div class="details-block">
                <div class="details-label">Original Price</div>
                <div class="details-value">@Model.OriginalPrice</div>
            </div>

            <!-- DISCOUNTED PRICE -->
            <div class="details-block">
                <div class="details-label">Discounted Price</div>
                <div class="details-value">@Model.DiscountedPrice</div>
            </div>

            <!-- QUANTITY -->
            <div class="details-block">
                <div class="details-label">Quantity Available</div>
                <div class="details-value">
                    @Model.QuantityAvailable
                    @if (Model.IsLowStock)
                    {
                        <span class="pill pill-warning">Low stock</span>
                    }
                </div>
            </div>

            <!-- END DATE -->
            <div class="details-block">
                <div class="details-label">Ends At</div>
                <div class="details-value">
                    @Model.EndsAt.ToString("dd.MM.yyyy HH:mm")
                </div>
            </div>

            <!-- STATUS -->
            <div class="details-block">
                <div class="details-label">Status</div>
                <div class="details-value">
                    <span class="pill @(isExpired ? "pill-danger" : "pill-success")">
                        @(isExpired ? "Expired" : "Active")
                    </span>
                </div>
            </div>

            <!-- IMAGE -->
            <div class="details-block details-block-wide">
                <div class="details-label">Image</div>
                <div class="details-value">
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <img class="admin-thumb-large"
                             src="@Model.ImageUrl"
                             alt="Offer image" />
                    }
                    else
                    {
                        <span class="muted">No image</span>
                    }
                </div>
            </div>

            <!-- TAGS -->
            <div class="details-block details-block-wide">
                <div class="details-label">Tags</div>
                <div class="details-value">

                    @if (!tags.Any())
                    {
                        <span class="muted">No tags</span>
                    }
                    else
                    {
                        foreach (var ot in tags)
                        {
                            <span class="pill pill-neutral">
                                @ot.Tag?.Name
                            </span>
                        }
                    }

                </div>
            </div>

            <!-- DESCRIPTION -->
            <div class="details-block details-block-wide">
                <div class="details-label">Description</div>
                <div class="details-value">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)
                </div>
            </div>

        </div>

        <div class="admin-actions-row mt-4">
            <form asp-action="DeleteOffer" method="post"
                  onsubmit="return confirm('Delete this offer?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn-delete" type="submit">Delete</button>
            </form>
        </div>

    </div>

</div>