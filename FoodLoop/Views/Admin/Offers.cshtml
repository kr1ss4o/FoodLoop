@model IEnumerable<FoodLoop.Models.Entities.Offer>
@using FoodLoop.Models.ViewModels
@{
    ViewData["Title"] = "Offers";
}

<h1>Offers</h1>

<form method="get" class="admin-search">
    <input type="text" name="search" value="@ViewBag.Search" placeholder="Search..." />
    <button type="submit">Search</button>
</form>

<table class="admin-table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Restaurant</th>
            <th>Price</th>
            <th>Ends</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Title</td>
                <td>@o.Restaurant.Name</td>
                <td>@o.DiscountedPrice</td>
                <td>@o.EndsAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <form asp-action="DeleteOffer"
                          method="post"
                          onsubmit="return confirmDelete();">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@o.Id" />
                        <button class="btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("_SectionPagination",
new PaginationViewModel
{
    CurrentPage = ViewBag.CurrentPage,
    TotalPages = ViewBag.TotalPages,
    Action = ViewContext.RouteData.Values["action"]?.ToString(),
    Controller = "Admin",
    Query = ViewBag.Search
})