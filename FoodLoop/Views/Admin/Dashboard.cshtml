@model dynamic

@{
    Layout = "_AdminLayout";
}

<div class="admin-dashboard">

    <h2>Admin Dashboard</h2>

    <div class="admin-cards">

        <div class="admin-card">
            <h3>Restaurants</h3>
            <span>@Model.Restaurants</span>
        </div>

        <div class="admin-card">
            <h3>Offers</h3>
            <span>@Model.Offers</span>
        </div>

        <div class="admin-card">
            <h3>Reservations</h3>
            <span>@Model.Reservations</span>
        </div>

        <div class="admin-card">
            <h3>Reviews</h3>
            <span>@Model.Reviews</span>
        </div>

    </div>

</div>