@model dynamic

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="admin-page">

    <div class="admin-page-head">
        <div>
            <h1 class="admin-page-title text-center">Администраторско табло</h1>
            <div class="admin-page-subtitle text-center">Обща статистика на приложението</div>
        </div>
    </div>

    <div class="admin-kpi-grid">

        <a class="admin-kpi" asp-controller="AdminRestaurants" asp-action="Restaurants">
            <div class="admin-kpi-icon">
                <i class="bi bi-shop"></i>
            </div>
            <div class="admin-kpi-body">
                <div class="admin-kpi-label">Общо ресторанти</div>
                <div class="admin-kpi-value js-count" data-count="@Model.Restaurants">0</div>
            </div>
            <div class="admin-kpi-arrow">
                <i class="bi bi-arrow-right-short"></i>
            </div>
        </a>

        <a class="admin-kpi" asp-controller="AdminOffers" asp-action="Offers">
            <div class="admin-kpi-icon">
                <i class="bi bi-megaphone"></i>
            </div>
            <div class="admin-kpi-body">
                <div class="admin-kpi-label">Общо активни оферти</div>
                <div class="admin-kpi-value js-count" data-count="@Model.Offers">0</div>
            </div>
            <div class="admin-kpi-arrow">
                <i class="bi bi-arrow-right-short"></i>
            </div>
        </a>

        <a class="admin-kpi" asp-controller="AdminReservations" asp-action="Reservations">
            <div class="admin-kpi-icon">
                <i class="bi bi-receipt"></i>
            </div>
            <div class="admin-kpi-body">
                <div class="admin-kpi-label">Общо поръчки</div>
                <div class="admin-kpi-value js-count" data-count="@Model.Reservations">0</div>
            </div>
            <div class="admin-kpi-arrow">
                <i class="bi bi-arrow-right-short"></i>
            </div>
        </a>

        <a class="admin-kpi" asp-controller="AdminReviews" asp-action="Reviews">
            <div class="admin-kpi-icon">
                <i class="bi bi-star"></i>
            </div>
            <div class="admin-kpi-body">
                <div class="admin-kpi-label">Общо ревюта</div>
                <div class="admin-kpi-value js-count" data-count="@Model.Reviews">0</div>
            </div>
            <div class="admin-kpi-arrow">
                <i class="bi bi-arrow-right-short"></i>
            </div>
        </a>

        <a class="admin-kpi" asp-controller="AdminCategories" asp-action="Categories">
            <div class="admin-kpi-icon">
                <i class="bi bi-grid"></i>
            </div>
            <div class="admin-kpi-body">
                <div class="admin-kpi-label">Общо категории</div>
                <div class="admin-kpi-value js-count" data-count="@Model.Categories">0</div>
            </div>
            <div class="admin-kpi-arrow">
                <i class="bi bi-arrow-right-short"></i>
            </div>
        </a>

        <a class="admin-kpi" asp-controller="AdminTags" asp-action="Tags">
            <div class="admin-kpi-icon">
                <i class="bi bi-tags"></i>
            </div>
            <div class="admin-kpi-body">
                <div class="admin-kpi-label">Общо тагове</div>
                <div class="admin-kpi-value js-count" data-count="@Model.Tags">0</div>
            </div>
            <div class="admin-kpi-arrow">
                <i class="bi bi-arrow-right-short"></i>
            </div>
        </a>

    </div>
</div>

@section Scripts {
    <script>
        (function () {
          const reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

          function animate(el) {
            const target = parseInt(el.dataset.count || "0", 10) || 0;
            if (reduce) { el.textContent = target.toString(); return; }

            const duration = 700; // ms
            const start = performance.now();
            const from = 0;

            function tick(now) {
              const t = Math.min(1, (now - start) / duration);
              // easeOutCubic
              const eased = 1 - Math.pow(1 - t, 3);
              const val = Math.round(from + (target - from) * eased);
              el.textContent = val.toString();
              if (t < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          }

          document.querySelectorAll(".js-count").forEach(animate);
        })();
    </script>
}