@model dynamic
@{
    ViewData["Title"] = "Dashboard";
}

<div class="admin-wrapper">

    <div class="admin-header">
        <h1 class="admin-title">Admin Dashboard</h1>
    </div>

    <div class="stats-grid">

        <div class="stat-card">
            <h3>Total Restaurants</h3>
            <p>@Model.Restaurants</p>
        </div>

        <div class="stat-card">
            <h3>Total Offers</h3>
            <p>@Model.Offers</p>
        </div>

        <div class="stat-card">
            <h3>Total Orders</h3>
            <p>@Model.Reservations</p>
        </div>

        <div class="stat-card">
            <h3>Total Reviews</h3>
            <p>@Model.Reviews</p>
        </div>

    </div>

</div>