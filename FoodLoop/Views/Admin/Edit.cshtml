@model FoodLoop.Models.ViewModels.Admin.EditRestaurantViewModel

<h2>Редакция на ресторант</h2>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Име</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Бизнес имейл</label>
        <input asp-for="BusinessEmail" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Телефон</label>
        <input asp-for="Phone" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Адрес</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input asp-for="ImageUrl" class="form-control" />
    </div>

    <button class="btn btn-primary">Запази</button>
</form>