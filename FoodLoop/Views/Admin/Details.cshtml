@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using FoodLoop.Helpers
@model object

@{
    Layout = "_Layout";

    var type = Model.GetType();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    var id = type.GetProperty("Id")?.GetValue(Model);

    var properties = type.GetProperties()
        .Select(p => new
        {
            Property = p,
            Display = p.GetCustomAttribute<DisplayAttribute>()
        })
        .Where(x => x.Display != null)
        .ToList();

    var banner = properties
        .FirstOrDefault(p => p.Property.Name.Contains("BannerImageUrl"));

    var mediaProps = properties
        .Where(p => p.Property.Name.Contains("ImageUrl") || p.Property.Name.Contains("IconUrl"))
        .ToList();

    var normalProps = properties
        .Where(p => !p.Property.Name.Contains("ImageUrl") &&
                    !p.Property.Name.Contains("IconUrl") &&
                    !p.Property.Name.Contains("BannerImageUrl"))
        .ToList();
}

@functions {

    string BgName(string type)
    {
        return type switch
        {
            "Restaurant" => "Ресторант",
            "Offer" => "Оферта",
            "Category" => "Категория",
            "Tag" => "Таг",
            "Review" => "Ревю",
            "Reservation" => "Резервация",
            "Order" => "Поръчка",
            "User" => "Потребител",
            _ => type
        };
    }
}

<div class="admin-container">

    <!-- HERO / BANNER -->
    @if (banner != null)
    {
        var bannerValue = banner.Property.GetValue(Model);

        if (bannerValue != null)
        {
            <div class="admin-details-hero"
                 style="background-image:url('@bannerValue')">
            </div>
        }
    }

    <!-- HEADER -->

    <div class="admin-details-header">

        <div>

            <h1 class="admin-details-title">
                @BgName(type.Name)
            </h1>

            <div class="admin-details-meta">

                <span class="admin-badge">
                    ID: @id
                </span>

                <span class="admin-badge">
                    Модел: @BgName(type.Name)
                </span>

            </div>

        </div>

        @if (type.Name != "Review")
        {
            <a asp-controller="@controller"
               asp-action="Edit"
               asp-route-id="@id"
               class="admin-btn admin-btn-primary">
                Edit
            </a>
        }

    </div>


    <!-- MEDIA -->
    @if (mediaProps.Any())
    {
        <div class="admin-details-section">

            <h3 class="admin-section-title">
                Медиа
            </h3>

            <div class="admin-media-grid">

                @foreach (var item in mediaProps)
                {
                    var value = item.Property.GetValue(Model);

                    if (value != null)
                    {
                        <img src="@value"
                             class="admin-detail-image" />
                    }
                }

            </div>

        </div>
    }


    <!-- INFORMATION -->

    <div class="admin-details-section">

        <h3 class="admin-section-title">
            Информация
        </h3>

        <div class="admin-details-grid">

            @foreach (var item in normalProps)
            {
                var prop = item.Property;
                var label = item.Display?.Name ?? prop.Name;
                var value = prop.GetValue(Model);

                <div class="admin-detail-card">

                    <div class="admin-detail-label">
                        @label
                    </div>

                    <div class="admin-detail-value">

                        @{
                            if (value == null)
                            {
                                <span class="admin-null">null</span>
                                ;
                                return;
                            }

                            var valueType = value.GetType();
                        }

                        @* DATE *@
                        @if (value is DateTime dt)
                        {
                            @dt.ToString("dd.MM.yyyy HH:mm")
                        }

                        @* PRICE *@
                        else if (value is decimal price)
                        {
                            @($"{price:F2} лв")
                        }

                        @* BOOLEAN *@
                        else if (value is bool b)
                        {
                            @(b ? "Yes" : "No")
                        }

                        @* TAG COLLECTION *@
                        else if (value is IEnumerable<object> list && prop.Name.Contains("Tags"))
                        {
                            <div class="admin-tags">

                                @foreach (var tag in list)
                                {
                                    <span class="admin-tag">
                                        @tag
                                    </span>
                                }

                            </div>
                        }

                        @* NAVIGATION ENTITY *@
                        else if (valueType.Namespace?.Contains("Entities") == true)
                        {
                            var nameProp = valueType.GetProperty("Name");
                            var idProp = valueType.GetProperty("Id");

                            var entityId = idProp?.GetValue(value);
                            var entityName = valueType.Name;

                            if (nameProp != null)
                            {
                                <a asp-controller="@AdminControllerHelper.Get(entityName)"
                                   asp-action="Details"
                                   asp-route-id="@entityId"
                                   class="admin-link">

                                    @nameProp.GetValue(value)

                                </a>
                            }
                            else
                            {
                                @value
                            }
                        }

                        else
                        {
                            @value
                        }

                    </div>

                </div>
            }

        </div>

    </div>

</div>