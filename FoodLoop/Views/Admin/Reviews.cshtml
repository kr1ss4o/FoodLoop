@model IEnumerable<FoodLoop.Models.Entities.Review>
@using FoodLoop.Models.ViewModels;
@{
    ViewData["Title"] = "Reviews";
}

<h1>Reviews</h1>

<table class="admin-table">
    <thead>
        <tr>
            <th>Restaurant</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>
                    @{
                        var restaurantName = r.Reservation.Items
                        .FirstOrDefault()?
                        .Offer?
                        .Restaurant?
                        .Name ?? "N/A";
                    }
                    @restaurantName
                </td>
                <td>@r.Rating</td>
                <td>@r.Comment</td>
                <td>@r.CreatedAt</td>
                <td>
                    <form asp-action="DeleteReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@r.Id" />
                        <button class="btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
@await Html.PartialAsync("_SectionPagination",
new PaginationViewModel
{
    CurrentPage = ViewBag.CurrentPage,
    TotalPages = ViewBag.TotalPages,
    Action = ViewContext.RouteData.Values["action"]?.ToString(),
    Controller = "Admin",
    Query = ViewBag.Search
})