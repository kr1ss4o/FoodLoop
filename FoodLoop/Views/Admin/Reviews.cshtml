@using FoodLoop.Models.ViewModels
@model IEnumerable<FoodLoop.Models.Entities.Review>

@{
    Layout = "_Layout";
}

<div class="admin-section">

    <div class="admin-page-head">

        <div>
            <h2 class="admin-page-title">Reviews</h2>
            <p class="admin-page-subtitle">Manage all reviews</p>
        </div>

        <div class="admin-toolbar">

            <form method="get" class="admin-search">

                <i class="bi bi-search"></i>

                <input type="text"
                       name="query"
                       value="@Context.Request.Query["query"]"
                       placeholder="Search reviews..." />

            </form>

            <a asp-action="Create"
               class="admin-btn admin-btn-primary">

                <i class="bi bi-plus-lg"></i>
                Create

            </a>

        </div>

    </div>

    <div class="admin-card">
        <partial name="_AdminTable"
                 model="Model.Cast<object>()" />
    </div>

    <partial name="_SectionPagination"
             model="(PaginationViewModel)ViewBag.Pagination" />

</div>