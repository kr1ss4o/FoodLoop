@model FoodLoop.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = Model.FullName + "'s profile";
    ViewData["BodyClass"] = "profile-body";
}

<!-- CORRECT CSS LOADING -->
<link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/modal.css" asp-append-version="true" />

<div class="profile-wrapper">

    <h1 class="title">Welcome, @Model.FullName</h1>

    <!-- MAIN PROFILE BOX -->
    <div class="profile-box">
        <div class="profile-info">
            <p><strong>Name:</strong><br /> @Model.FullName</p>
            <p><strong>Email:</strong><br /> @Model.Email</p>
            <p><strong>Phone:</strong><br /> @Model.PhoneNumber</p>

            <button id="epm-open" class="edit-btn">Edit</button>
            @await Html.PartialAsync("_EditProfileModal")
        </div>

        <div class="profile-photo">
            <img class="profile-photo"
                 src="@(string.IsNullOrEmpty(Model.ProfileImageUrl)
                                         ? "/images/default-avatar.jpg"
                                         : Model.ProfileImageUrl)" />
        </div>
    </div>

    <!-- INSIGHTS -->
    <h2 class="section-title">Insights:</h2>

    <div class="insights-box">
        <div class="insight">
            <strong>Total orders:</strong>
            <div>@Model.TotalOrders</div>
        </div>
        <div class="insight">
            <strong>Money spent:</strong>
            <div>@Model.MoneySpent EUR</div>
        </div>
        <div class="insight">
            <strong>Account created:</strong>
            <div>@Model.AccountCreated.ToShortDateString()</div>
        </div>
    </div>

    <!-- BUTTONS -->
    <form method="post" action="/Account/Logout" onsubmit="return confirmLogout();">
        <button class="logout-btn">Logout</button>
    </form>

    <form method="post" action="/Profile/Delete" onsubmit="return confirmDelete();">
        <button class="delete-btn">Delete Account</button>
    </form>
</div>

<!-- FIXED JS IMPORT -->
<script src="~/js/modal.js" asp-append-version="true"></script>

@section Scripts {
    <script>
        @if (TempData["Success"] != null)
        {
                <text>showToast('@TempData["Success"]', 'success');</text>
        }
        @if (TempData["Error"] != null)
        {
                <text>showToast('@TempData["Error"]', 'error');</text>
        }
    </script>
}