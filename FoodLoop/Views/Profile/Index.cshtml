@model FoodLoop.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />

<div class="profile-container">

    <!-- HEADER -->

    <div class="profile-banner">

        <div class="profile-avatar-wrap">
            <img src="@(string.IsNullOrEmpty(Model.ProfileImageUrl)
                             ? "/images/default-avatar.jpg"
                             : Model.ProfileImageUrl)"
                 class="profile-avatar" />
        </div>

        <div class="profile-main">

            <h1>@Model.FullName</h1>

            <div class="profile-meta">
                <span>
                    <i class="bi bi-envelope"></i>
                    @Model.Email
                </span>

                <span>
                    <i class="bi bi-telephone"></i>
                    @Model.PhoneNumber
                </span>
            </div>

            <button id="epm-open" class="btn-edit">
                Редактирай профил
            </button>

        </div>

    </div>

    <!-- STATS -->

    <div class="stats-wrapper">

        <div class="profile-stats">

            <div class="stat-badge">
                <div class="stat-icon stat-orders">
                    <i class="bi bi-bag"></i>
                </div>
                <div class="stat-info">
                    <span>Общо поръчки</span>
                    <strong>@Model.TotalOrders</strong>
                </div>
            </div>

            <div class="stat-badge">
                <div class="stat-icon stat-money">
                    <i class="bi bi-currency-euro"></i>
                </div>
                <div class="stat-info">
                    <span>Общо похарчени</span>
                    <strong>@Model.MoneySpent EUR</strong>
                </div>
            </div>

            <div class="stat-badge">
                <div class="stat-icon stat-date">
                    <i class="bi bi-calendar3"></i>
                </div>
                <div class="stat-info">
                    <span>Профил от</span>
                    <strong>@Model.AccountCreated.ToString("dd.MM.yyyy")</strong>
                </div>
            </div>

        </div>
    </div>

    <!-- REVIEWS -->

    <div class="section-header">
        <h3>Моите ревюта</h3>

        <a asp-controller="Reviews"
           asp-action="MyReviews"
           class="section-link">
            Виж всички
        </a>
    </div>

    <div class="reviews-box">

        @if (!Model.Reviews.Any())
        {
            <div class="reviews-empty">
                Нямате ревюта
            </div>
        }
        else
        {
            foreach (var review in Model.Reviews)
            {
                <div class="review-row">

                    <div class="review-restaurant">
                        @review.RestaurantName
                    </div>

                    <div class="review-rating">
                        ⭐ @review.Rating
                    </div>

                    <div class="review-comment">
                        @review.Comment
                    </div>

                </div>
            }
        }

    </div>

    <!-- ORDERS -->

    <div class="section-header">

        <h3>Последни поръчки</h3>

        <a asp-controller="Orders"
           asp-action="MyOrders"
           class="section-link">
            Виж всички
        </a>

    </div>

    <div class="orders-box">

        @foreach (var order in Model.RecentOrders)
        {

            <div class="order-item-wrapper">

                <!-- ORDER ROW -->

                <div class="order-row js-order-toggle">

                    <div class="order-image">
                        <i class="bi bi-bag"></i>
                    </div>

                    <div class="order-content">

                        <div class="order-title">
                            Поръчка #@order.Id
                        </div>

                        <div class="order-meta">
                            @order.TotalPrice EUR
                        </div>

                        <div class="order-status status-@order.Status.ToLower()">
                            @order.Status
                        </div>

                    </div>

                    <div class="order-arrow">
                        <i class="bi bi-chevron-down"></i>
                    </div>

                </div>

                <!-- ORDER DETAILS -->

                <div class="order-details">

                    <div class="order-details-inner">

                        <div>
                            <strong>Дата:</strong>
                            @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </div>

                        <div>
                            <strong>Ресторант:</strong>
                            @order.RestaurantName
                        </div>

                        <div class="order-items">

                            @foreach (var item in order.Items)
                            {
                                <div>
                                    @item.OfferTitle × @item.Quantity
                                </div>
                            }

                        </div>

                        <div class="order-total">
                            Общо: @order.TotalPrice EUR
                        </div>

                    </div>

                </div>

            </div>

        }

    </div>

    <!-- ACTIONS -->

    <div class="profile-actions-box">

        <form method="post" action="/Account/Logout">
            <button class="action-row logout">
                <i class="bi bi-box-arrow-right"></i>
                Изход
            </button>
        </form>

        <a href="mailto:foodloop@gmail.com?subject=FoodLoop Report"
           class="action-row report">

            <i class="bi bi-flag"></i>
            Направи сигнал

        </a>

        <form method="post"
              action="/Profile/Delete"
              onsubmit="return confirm('Сигурни ли сте?');">

            <button class="action-row delete">
                <i class="bi bi-trash"></i>
                Изтрий профила
            </button>

        </form>

    </div>

</div>

@await Html.PartialAsync("_EditProfileModal", Model.EditProfileModal)

@section Scripts {

    <script src="~/js/profile-edit-modal.js"></script>

    <script>

                document.querySelectorAll(".js-order-toggle").forEach(row => {

            row.addEventListener("click", () => {

                const wrapper = row.closest(".order-item-wrapper")
                const details = wrapper.querySelector(".order-details")

                wrapper.classList.toggle("open")
                details.classList.toggle("open")

            })

        })

    </script>

}