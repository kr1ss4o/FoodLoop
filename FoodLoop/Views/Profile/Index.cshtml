@model FoodLoop.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["BodyClass"] = "profile-body";
}

<link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />

<div class="profile-container">

    <!-- HEADER -->
    <div class="profile-header">
        <div class="profile-avatar-box">
            <img id="prof-photo" src="@(string.IsNullOrEmpty(Model.ProfileImageUrl)
                                         ? "/images/default-avatar.jpg"
                                         : Model.ProfileImageUrl)"
                 class="profile-avatar" />
        </div>

        <div class="profile-header-info">
            <h1 id="prof-name" class="profile-name">@Model.FullName</h1>
            <p id="prof-email" class="profile-email">@Model.Email</p>
            <p id="prof-phone" class="profile-phone">@Model.PhoneNumber</p>

            <button id="epm-open" class="btn-edit">Edit profile</button>
        </div>
    </div>

    <!-- INSIGHTS -->
    <h2 class="section-title">Your activity</h2>

    <div class="insights-grid">

        <div class="insight-card">
            <span class="insight-label">Total orders</span>
            <span class="insight-value">@Model.TotalOrders</span>
        </div>

        <div class="insight-card">
            <span class="insight-label">Money spent</span>
            <span class="insight-value">@Model.MoneySpent EUR</span>
        </div>

        <div class="insight-card">
            <span class="insight-label">Member since</span>
            <span class="insight-value">@Model.AccountCreated.ToShortDateString()</span>
        </div>

    </div>

    <!-- ACTIONS -->
    <div class="profile-actions">
        <form method="post" action="/Account/Logout">
            <button class="btn-logout">Log out</button>
        </form>

        <form method="post" action="/Profile/Delete"
              onsubmit="return confirm('Are you sure you want to delete your account?');">
            <button class="btn-delete">Delete account</button>
        </form>
    </div>

</div>

<!-- MODAL -->
@await Html.PartialAsync("_EditProfileModal")

@section Scripts {
    <script src="~/js/edit-profile-modal.js"></script>
}